                    }
                  },
                  "block_order": [
                    "text_jYymRw"
                  ]
                },
                "accordion_row_kdihpA": {
                  "type": "_accordion-row",
                  "settings": {
                    "heading": "Post-wedding Care",
                    "open_by_default": false,
                    "icon": "none",
                    "width": 20
                  },
                  "blocks": {
                    "text_LpmafG": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Did you know MWL offers professional gown cleaning to restore your dress after your wedding day? Ask your stylist during your appointment about how to arrange this service.</p>",
                        "width": "100%",
                        "max_width": "normal",
                        "alignment": "left",
                        "type_preset": "rte",
                        "enable_mobile_size": false,
                        "mobile_font_size": "1rem",
