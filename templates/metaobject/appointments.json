                "accordion_row_XdK33f": {
                  "type": "_accordion-row",
                  "settings": {
                    "heading": "Payment",
                    "open_by_default": false,
                    "icon": "none",
                    "width": 20
                  },
                  "blocks": {
                    "text_DyeQxR": {
                      "type": "text",
                      "settings": {
                        "text": "<p>We have a variety of payment options available. We recommend having your bank or credit card with you to complete purchase on the day. Alternatively, we offer partial upfront payment through MWL pay on Australian orders. Your stylist will be able to provide more information during your appointment.</p>",
                        "width": "100%",
                        "max_width": "normal",
                        "alignment": "left",
                        "type_preset": "rte",
                        "enable_mobile_size": false,
                        "mobile_font_size": "1rem",
                        "font": "var(--font-body--family)",
                        "font_size": "1rem",
                        "line_height": "normal",
                        "letter_spacing": "normal",
                        "case": "none",
