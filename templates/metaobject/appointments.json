                  "blocks": {
                    "text_pzdxmG": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Please see our Terms and Conditions <a href=\"https://mwlbride.com/pages/terms-and-conditions\" target=\"_blank\" title=\"https://mwlbride.com/pages/terms-and-conditions\">here.</a> </p>",
                        "width": "100%",
