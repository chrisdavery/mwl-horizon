                  },
                  "blocks": {
                    "text_TG9r7m": {
                      "type": "text",
                      "settings": {
                        "text": "<p>We offer MWL Gift Vouchers which can be purchased <a href=\"https://www.madewithlovebridal.com/shop/gift-vouchers/\"><span style=\"text-decoration:underline\"><em>here</em></span><span style=\"text-decoration:underline\"> </span></a>before or after your appointment. These are the perfect gift from a loved one. Our MWL exclusive boutiques e-gift cards are delivered directly to the special someone’s inbox.</p>",
