                  },
                  "block_order": [
                    "text_DyeQxR"
                  ]
                },
                "accordion_row_EbyYjN": {
                  "type": "_accordion-row",
                  "settings": {
                    "heading": "Appointment Cancellations",
                    "open_by_default": false,
                    "icon": "none",
                    "width": 20
                  },
                  "blocks": {
                    "text_kym6Cy": {
                      "type": "text",
                      "settings": {
                        "text": "<p>We have a 48 hour cancellation policy, so if you did want to cancel/reschedule your appointment, please ensure you do this at least two days before your appointment. If cancelling on a weekend, please reply to your confirmation text message as our stylists do not have access to email on the weekends.</p>",
                        "width": "100%",
                        "max_width": "normal",
                        "alignment": "left",
                        "type_preset": "rte",
                        "enable_mobile_size": false,
                        "mobile_font_size": "1rem",
