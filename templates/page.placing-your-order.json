          "blocks": {
            "text_fr4DDx": {
              "type": "text",
              "name": "t:names.heading",
              "settings": {
                "text": "<h2>OUR PROCESS & PLACING YOUR ORDER</h2>",
                "width": "fit-content",
                "max_width": "normal",
                "alignment": "left",
                "type_preset": "h4",
                "enable_mobile_size": false,
                "mobile_font_size": "1rem",
