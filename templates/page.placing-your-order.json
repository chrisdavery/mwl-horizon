    "custom_liquid_V67VtJ": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "Redirect script (do not remove))",
      "settings": {
        "custom_liquid": "{%- if request.design_mode -%}\n  {% break %}\n{% endif %}\n<script>\n(async () => {\n  const EUROPE = new Set([\n    'AL','AD','AT','BY','BE','BA','BG','HR','CY','CZ','DK','EE','FO','FI','FR','DE','GI','GR','GG','HU','IS',\n    'IE','IM','IT','JE','LV','LI','LT','LU','MT','MD','MC','ME','MK','NL','NO','PL','PT','RO','RU','SM','RS',\n    'SK','SI','ES','SE','CH','UA','GB','VA'\n  ]);\n\n  try {\n    const url =\n      `${window.Shopify.routes.root}browsing_context_suggestions.json` +\n      `?country[enabled]=true&country[exclude]=${window.Shopify.country}` +\n      `&language[enabled]=true&language[exclude]=${window.Shopify.language}`;\n\n    const res = await fetch(url);\n    if (!res.ok) throw new Error(`HTTP ${res.status}`);\n    const data = await res.json();\n\n    const c = data?.detected_values?.country;\n    if (!c) return;\n\n    const code = (c.handle || '').toUpperCase();\n    const name = (c.name || '').trim();\n\n    // default target\n    let target = '/pages/the-next-step';\n\n    if (code === 'GB' || name === 'United Kingdom') {\n      target = '/pages/the-next-step-uk';\n    } else if (EUROPE.has(code)) {\n      target = '/pages/the-next-step-eu';\n    }\n\n    // prevent redirect loop\n    if (window.location.pathname !== target) {\n      window.location.href = target;\n    }\n  } catch (err) {\n    console.warn('[country-autoselect] Failed:', err);\n  }\n})();\n</script>",
        "color_scheme": "",
        "section_width": "page-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    }
