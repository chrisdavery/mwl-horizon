            },
            "accordion_ikEnk3": {
              "type": "accordion",
              "name": "t:names.accordion",
              "settings": {
                "icon": "plus",
                "dividers": true,
                "type_preset": "h5",
                "inherit_color_scheme": true,
                "color_scheme": "",
                "border": "none",
                "border_width": 1,
                "border_opacity": 100,
                "border_radius": 0,
                "padding-block-start": 0,
