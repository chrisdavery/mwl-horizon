                  },
                  "blocks": {
                    "text_hWhQxC": {
                      "type": "text",
                      "settings": {
                        "text": "<p>We are always on the look out for talented individuals to join our team across our nationwide boutiques, please reach out to laura@mwlbride.com today to express your interest.</p>",
                        "width": "100%",
