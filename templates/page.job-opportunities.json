                "accordion_row_N9VTyq": {
                  "type": "_accordion-row",
                  "name": "Stylist Position - Continous",
                  "settings": {
                    "heading": "Looking For A Stylist Role With Mwl? | AUSTRALIA WIDE",
                    "open_by_default": false,
                    "icon": "none",
                    "width": 20
                  },
                  "blocks": {
                    "text_hWhQxC": {
                      "type": "text",
                      "settings": {
                        "text": "<p>We are always on the look out for talented individuals to join our team across our nationwide boutiques, please reach out to laura@mwlbride.com today to express your interest.</p>",
                        "width": "100%",
                        "max_width": "normal",
                        "alignment": "left",
                        "type_preset": "custom",
                        "enable_mobile_size": false,
                        "mobile_font_size": "1rem",
