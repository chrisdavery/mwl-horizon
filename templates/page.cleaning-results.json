          "blocks": {
            "text_YYJEqM": {
              "type": "text",
              "name": "t:names.heading",
              "settings": {
                "text": "<h2>CLEANING TERMS AND CONDITIONS</h2>",
                "width": "fit-content",
                "max_width": "normal",
                "alignment": "left",
                "type_preset": "custom",
                "enable_mobile_size": false,
                "mobile_font_size": "1rem",
