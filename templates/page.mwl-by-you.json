                  "blocks": {
                    "text_hWhQxC": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Our MWL By You custom service is available across all exclusive boutiques, we welcome you to book an appointment <a href=\"/pages/appointments\" target=\"_blank\" title=\"Book MWL Appointment\">here</a>.</p><p>The MWL By You service is also available at our respected partners. Explore worldwide retailers <a href=\"https://madewithlovebridal.com/pages/store-locator\" target=\"_blank\" title=\"https://madewithlovebridal.com/pages/store-locator\">here</a>.</p>",
