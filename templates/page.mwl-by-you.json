                  },
                  "blocks": {
                    "text_PcEMT3": {
                      "type": "text",
                      "settings": {
                        "text": "<p>All MWL styles are available to be customised to find your perfect pairing.</p>",
                        "width": "100%",
                        "max_width": "normal",
                        "alignment": "left",
                        "type_preset": "custom",
                        "enable_mobile_size": false,
                        "mobile_font_size": "1rem",
                        "font": "var(--font-body--family)",
