                },
                "accordion_row_N9VTyq": {
                  "type": "_accordion-row",
                  "settings": {
                    "heading": "Is The Mwl By You Custom Service Only Available At Australian Boutiques?",
                    "open_by_default": false,
                    "icon": "none",
                    "width": 20
