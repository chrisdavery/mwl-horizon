    {% if page.handle == 'feedback' %}
  <!-- Zapier webhook for AI feedback form -->
  <script>
    console.log('Zapier snippet loaded');

    function attachToAIForm() {
      // Get the AI feedback web component
      const feedbackEl = document.querySelector('feedback-form-azm5cnkdvn09rnmhukaigenblocka0fe330xrq3m9');
      if (!feedbackEl) {
        console.log('Waiting for AI feedback component...');
        setTimeout(attachToAIForm, 500);
        return;
      }

      console.log('AI feedback component found');

      // Use MutationObserver to detect when internal form is added
      const observer = new MutationObserver((mutations, obs) => {
        const form = feedbackEl.querySelector('#contact_form');
        if (form) {
          console.log('Feedback form inside AI component found');

          // Attach submit listener
          form.addEventListener('submit', function(e) {
            console.log('Form submitted! Sending data to Zapier...');
            const formData = new FormData(form);

            fetch('https://hooks.zapier.com/hooks/catch/2280371/ugmebc1/', {
              method: 'POST',
              body: formData
            }).then(() => console.log('Request sent to Zapier'))
              .catch(err => console.error('Zapier webhook failed', err));
          });

          // Stop observing once form is found
          obs.disconnect();
        }
      });

      observer.observe(feedbackEl, { childList: true, subtree: true });
    }

    // Start the process
    attachToAIForm();
  </script>
{% endif %}

{% if page.handle == 'be-featured' %}
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      console.log('Zapier snippet loaded');

      const form = document.querySelector(
        '#ContactForm-Ad2Fnd2pLUjFMMjlLK__contact_form_V6JArK'
      );

      if (!form) {
        console.warn('Contact form not found');
        return;
      }

      console.log('Contact form found');

      let sent = false;

      form.addEventListener('submit', function () {
        if (sent) return;
        sent = true;

        console.log('Form submitted – sending to Zapier');

        const formData = new FormData(form);

        fetch('https://hooks.zapier.com/hooks/catch/2280371/uqbl477/', {
          method: 'POST',
          body: formData
        })
          .then(() => console.log('Zapier webhook sent successfully'))
          .catch(err => console.error('Zapier webhook failed', err));
      });
    });
  </script>
{% endif %}


  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script
      src="{{ 'critical.js' | asset_url }}"
      type="module"
      async
      blocking="render"
    ></script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}
  </body>
</html>
