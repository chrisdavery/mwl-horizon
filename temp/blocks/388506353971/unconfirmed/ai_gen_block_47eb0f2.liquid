{% doc %}
  @prompt
    A magazine-style editorial layout, double in length and add an accordion
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-editorial-layout-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.spacing_top }}px 0 {{ block.settings.spacing_bottom }}px;
  }

  .ai-editorial-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-editorial-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    align-items: start;
  }

  .ai-editorial-featured-{{ ai_gen_id }} {
    grid-column: span 7;
    position: relative;
  }

  .ai-editorial-featured-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-editorial-featured-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 3 / 4;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-editorial-featured-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-featured-content-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: {{ block.settings.content_padding }}px;
    background: linear-gradient(to top, rgba(0,0,0,0.7), rgba(0,0,0,0));
    color: #ffffff;
  }

  .ai-editorial-featured-category-{{ ai_gen_id }} {
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 8px;
    font-weight: 500;
    color: {{ block.settings.category_color }};
  }

  .ai-editorial-featured-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.featured_title_size }}px;
    line-height: 1.2;
    margin: 0 0 12px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .ai-editorial-featured-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.featured_excerpt_size }}px;
    line-height: 1.6;
    margin: 0 0 16px;
    opacity: 0.95;
  }

  .ai-editorial-featured-link-{{ ai_gen_id }} {
    display: inline-block;
    color: #ffffff;
    text-decoration: none;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    border-bottom: 1px solid #ffffff;
    padding-bottom: 2px;
    transition: opacity 0.3s ease;
  }

  .ai-editorial-featured-link-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-editorial-sidebar-{{ ai_gen_id }} {
    grid-column: span 5;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.sidebar_gap }}px;
  }

  .ai-editorial-article-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 20px;
    padding-bottom: {{ block.settings.sidebar_gap }}px;
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-editorial-article-{{ ai_gen_id }}:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .ai-editorial-article-image-{{ ai_gen_id }} {
    width: 120px;
    height: 120px;
    object-fit: cover;
  }

  .ai-editorial-article-placeholder-{{ ai_gen_id }} {
    width: 120px;
    height: 120px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-editorial-article-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-article-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .ai-editorial-article-category-{{ ai_gen_id }} {
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 8px;
    font-weight: 500;
    color: {{ block.settings.category_color_sidebar }};
  }

  .ai-editorial-article-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.article_title_size }}px;
    line-height: 1.3;
    margin: 0 0 8px;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: {{ block.settings.text_color }};
  }

  .ai-editorial-article-title-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .ai-editorial-article-title-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-editorial-article-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.article_excerpt_size }}px;
    line-height: 1.5;
    margin: 0;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
  }

  .ai-editorial-accordion-{{ ai_gen_id }} {
    grid-column: span 12;
    margin-top: {{ block.settings.accordion_spacing }}px;
  }

  .ai-editorial-accordion-header-{{ ai_gen_id }} {
    background-color: {{ block.settings.accordion_header_bg }};
    padding: 20px 30px;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border: 1px solid {{ block.settings.border_color }};
    transition: background-color 0.3s ease;
  }

  .ai-editorial-accordion-header-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.accordion_header_hover_bg }};
  }

  .ai-editorial-accordion-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.accordion_title_size }}px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin: 0;
    color: {{ block.settings.text_color }};
  }

  .ai-editorial-accordion-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
    color: {{ block.settings.text_color }};
  }

  .ai-editorial-accordion-icon-{{ ai_gen_id }}.active {
    transform: rotate(180deg);
  }

  .ai-editorial-accordion-content-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
    border-left: 1px solid {{ block.settings.border_color }};
    border-right: 1px solid {{ block.settings.border_color }};
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-editorial-accordion-content-{{ ai_gen_id }}.active {
    max-height: 3000px;
  }

  .ai-editorial-accordion-inner-{{ ai_gen_id }} {
    padding: 30px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.accordion_gap }}px;
  }

  .ai-editorial-accordion-article-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 20px;
  }

  .ai-editorial-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 989px) {
    .ai-editorial-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-editorial-featured-{{ ai_gen_id }},
    .ai-editorial-sidebar-{{ ai_gen_id }},
    .ai-editorial-accordion-{{ ai_gen_id }} {
      grid-column: span 1;
    }

    .ai-editorial-featured-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.featured_title_size | times: 0.7 }}px;
    }

    .ai-editorial-featured-excerpt-{{ ai_gen_id }} {
      font-size: {{ block.settings.featured_excerpt_size | times: 0.9 }}px;
    }

    .ai-editorial-accordion-inner-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-editorial-article-{{ ai_gen_id }},
    .ai-editorial-accordion-article-{{ ai_gen_id }} {
      grid-template-columns: 80px 1fr;
      gap: 16px;
    }

    .ai-editorial-article-image-{{ ai_gen_id }},
    .ai-editorial-article-placeholder-{{ ai_gen_id }} {
      width: 80px;
      height: 80px;
    }

    .ai-editorial-article-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.article_title_size | times: 0.9 }}px;
    }

    .ai-editorial-article-excerpt-{{ ai_gen_id }} {
      font-size: {{ block.settings.article_excerpt_size | times: 0.9 }}px;
    }

    .ai-editorial-accordion-header-{{ ai_gen_id }} {
      padding: 16px 20px;
    }

    .ai-editorial-accordion-inner-{{ ai_gen_id }} {
      padding: 20px;
    }

    .ai-editorial-accordion-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.accordion_title_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-editorial-layout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-editorial-container-{{ ai_gen_id }}">
    <div class="ai-editorial-grid-{{ ai_gen_id }}">
      <div class="ai-editorial-featured-{{ ai_gen_id }}">
        {% if block.settings.featured_image %}
          <img
            src="{{ block.settings.featured_image | image_url: width: 1200 }}"
            alt="{{ block.settings.featured_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.featured_image.width }}"
            height="{{ block.settings.featured_image.height }}"
            class="ai-editorial-featured-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-editorial-featured-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
            <div class="ai-editorial-empty-state-{{ ai_gen_id }}">
              Add a featured image
            </div>
          </div>
        {% endif %}

        <div class="ai-editorial-featured-content-{{ ai_gen_id }}">
          {% if block.settings.featured_category != blank %}
            <div class="ai-editorial-featured-category-{{ ai_gen_id }}">
              {{ block.settings.featured_category }}
            </div>
          {% endif %}

          {% if block.settings.featured_title != blank %}
            <h2 class="ai-editorial-featured-title-{{ ai_gen_id }}">
              {{ block.settings.featured_title }}
            </h2>
          {% endif %}

          {% if block.settings.featured_excerpt != blank %}
            <div class="ai-editorial-featured-excerpt-{{ ai_gen_id }}">
              {{ block.settings.featured_excerpt }}
            </div>
          {% endif %}

          {% if block.settings.featured_link != blank %}
            <a href="{{ block.settings.featured_link }}" class="ai-editorial-featured-link-{{ ai_gen_id }}">
              {{ block.settings.featured_link_text }}
            </a>
          {% endif %}
        </div>
      </div>

      <div class="ai-editorial-sidebar-{{ ai_gen_id }}">
        {% for i in (1..4) %}
          {% liquid
            assign article_image_key = 'article_' | append: i | append: '_image'
            assign article_category_key = 'article_' | append: i | append: '_category'
            assign article_title_key = 'article_' | append: i | append: '_title'
            assign article_excerpt_key = 'article_' | append: i | append: '_excerpt'
            assign article_link_key = 'article_' | append: i | append: '_link'

            assign article_image = block.settings[article_image_key]
            assign article_category = block.settings[article_category_key]
            assign article_title = block.settings[article_title_key]
            assign article_excerpt = block.settings[article_excerpt_key]
            assign article_link = block.settings[article_link_key]
          %}

          {% if article_title != blank or article_image != blank %}
            <article class="ai-editorial-article-{{ ai_gen_id }}">
              <div>
                {% if article_image %}
                  <img
                    src="{{ article_image | image_url: width: 240 }}"
                    alt="{{ article_image.alt | escape }}"
                    loading="lazy"
                    width="120"
                    height="120"
                    class="ai-editorial-article-image-{{ ai_gen_id }}"
                  >
                {% else %}
                  <div class="ai-editorial-article-placeholder-{{ ai_gen_id }}">
                    {{ 'product-apparel-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              <div class="ai-editorial-article-content-{{ ai_gen_id }}">
                {% if article_category != blank %}
                  <div class="ai-editorial-article-category-{{ ai_gen_id }}">
                    {{ article_category }}
                  </div>
                {% endif %}

                {% if article_title != blank %}
                  <h3 class="ai-editorial-article-title-{{ ai_gen_id }}">
                    {% if article_link != blank %}
                      <a href="{{ article_link }}">{{ article_title }}</a>
                    {% else %}
                      {{ article_title }}
                    {% endif %}
                  </h3>
                {% endif %}

                {% if article_excerpt != blank %}
                  <p class="ai-editorial-article-excerpt-{{ ai_gen_id }}">
                    {{ article_excerpt }}
                  </p>
                {% endif %}
              </div>
            </article>
          {% endif %}
        {% endfor %}
      </div>

      {% if block.settings.show_accordion %}
        <editorial-accordion-{{ ai_gen_id }} class="ai-editorial-accordion-{{ ai_gen_id }}">
          <div class="ai-editorial-accordion-header-{{ ai_gen_id }}" role="button" aria-expanded="false" tabindex="0">
            <h3 class="ai-editorial-accordion-title-{{ ai_gen_id }}">
              {{ block.settings.accordion_title }}
            </h3>
            <svg class="ai-editorial-accordion-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </div>

          <div class="ai-editorial-accordion-content-{{ ai_gen_id }}">
            <div class="ai-editorial-accordion-inner-{{ ai_gen_id }}">
              {% for i in (5..8) %}
                {% liquid
                  assign article_image_key = 'article_' | append: i | append: '_image'
                  assign article_category_key = 'article_' | append: i | append: '_category'
                  assign article_title_key = 'article_' | append: i | append: '_title'
                  assign article_excerpt_key = 'article_' | append: i | append: '_excerpt'
                  assign article_link_key = 'article_' | append: i | append: '_link'

                  assign article_image = block.settings[article_image_key]
                  assign article_category = block.settings[article_category_key]
                  assign article_title = block.settings[article_title_key]
                  assign article_excerpt = block.settings[article_excerpt_key]
                  assign article_link = block.settings[article_link_key]
                %}

                {% if article_title != blank or article_image != blank %}
                  <article class="ai-editorial-accordion-article-{{ ai_gen_id }}">
                    <div>
                      {% if article_image %}
                        <img
                          src="{{ article_image | image_url: width: 240 }}"
                          alt="{{ article_image.alt | escape }}"
                          loading="lazy"
                          width="120"
                          height="120"
                          class="ai-editorial-article-image-{{ ai_gen_id }}"
                        >
                      {% else %}
                        <div class="ai-editorial-article-placeholder-{{ ai_gen_id }}">
                          {{ 'product-apparel-1' | placeholder_svg_tag }}
                        </div>
                      {% endif %}
                    </div>

                    <div class="ai-editorial-article-content-{{ ai_gen_id }}">
                      {% if article_category != blank %}
                        <div class="ai-editorial-article-category-{{ ai_gen_id }}">
                          {{ article_category }}
                        </div>
                      {% endif %}

                      {% if article_title != blank %}
                        <h3 class="ai-editorial-article-title-{{ ai_gen_id }}">
                          {% if article_link != blank %}
                            <a href="{{ article_link }}">{{ article_title }}</a>
                          {% else %}
                            {{ article_title }}
                          {% endif %}
                        </h3>
                      {% endif %}

                      {% if article_excerpt != blank %}
                        <p class="ai-editorial-article-excerpt-{{ ai_gen_id }}">
                          {{ article_excerpt }}
                        </p>
                      {% endif %}
                    </div>
                  </article>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </editorial-accordion-{{ ai_gen_id }}>
      {% endif %}
    </div>
  </div>
</div>

<script>
  (function() {
    class EditorialAccordion{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.header = this.querySelector('.ai-editorial-accordion-header-{{ ai_gen_id }}');
        this.content = this.querySelector('.ai-editorial-accordion-content-{{ ai_gen_id }}');
        this.icon = this.querySelector('.ai-editorial-accordion-icon-{{ ai_gen_id }}');

        if (this.header && this.content) {
          this.header.addEventListener('click', this.toggle.bind(this));
          this.header.addEventListener('keydown', this.handleKeydown.bind(this));
        }
      }

      toggle() {
        const isActive = this.content.classList.contains('active');
        
        if (isActive) {
          this.content.classList.remove('active');
          this.icon.classList.remove('active');
          this.header.setAttribute('aria-expanded', 'false');
        } else {
          this.content.classList.add('active');
          this.icon.classList.add('active');
          this.header.setAttribute('aria-expanded', 'true');
        }
      }

      handleKeydown(event) {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          this.toggle();
        }
      }
    }

    customElements.define('editorial-accordion-{{ ai_gen_id }}', EditorialAccordion{{ ai_gen_id }});
  })();
</script>

