{% doc %}
  @prompt
    I want a small section to showcase 4 hero products, I want the main viewed product box to be slightly bigger than the other three boxes, the product should be enlarged when selected.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-products-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-hero-products-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-hero-products-heading-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
    color: {{ block.settings.heading_color }};
  }

  .ai-hero-products-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-hero-product-card-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    background-color: {{ block.settings.card_background }};
    cursor: pointer;
    transition: transform 0.3s ease;
  }

  .ai-hero-product-card-{{ ai_gen_id }}:first-child {
    grid-row: 1 / 3;
  }

  .ai-hero-product-card-{{ ai_gen_id }}.active {
    transform: scale(1.05);
    z-index: 10;
  }

  .ai-hero-product-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
  }

  .ai-hero-product-card-{{ ai_gen_id }}:first-child .ai-hero-product-image-wrapper-{{ ai_gen_id }} {
    padding-bottom: 100%;
  }

  .ai-hero-product-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-product-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-product-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-hero-product-info-{{ ai_gen_id }} {
    padding: 20px;
    text-align: center;
  }

  .ai-hero-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    font-weight: 600;
    margin: 0 0 8px;
    color: {{ block.settings.text_color }};
  }

  .ai-hero-product-card-{{ ai_gen_id }}:first-child .ai-hero-product-title-{{ ai_gen_id }} {
    font-size: calc({{ block.settings.product_title_size }}px * 1.3);
  }

  .ai-hero-product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_price_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 500;
  }

  .ai-hero-product-card-{{ ai_gen_id }}:first-child .ai-hero-product-price-{{ ai_gen_id }} {
    font-size: calc({{ block.settings.product_price_size }}px * 1.2);
  }

  .ai-hero-product-link-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-hero-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
    font-size: 14px;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-products-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.grid_gap | times: 0.7 }}px;
    }

    .ai-hero-product-card-{{ ai_gen_id }}:first-child {
      grid-row: auto;
    }

    .ai-hero-product-card-{{ ai_gen_id }}:first-child .ai-hero-product-image-wrapper-{{ ai_gen_id }} {
      padding-bottom: 100%;
    }
  }
{% endstyle %}

<hero-products-{{ ai_gen_id }} class="ai-hero-products-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-products-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-hero-products-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% liquid
      assign product_1 = block.settings.product_1
      assign product_2 = block.settings.product_2
      assign product_3 = block.settings.product_3
      assign product_4 = block.settings.product_4
      assign has_products = false

      if product_1 != blank or product_2 != blank or product_3 != blank or product_4 != blank
        assign has_products = true
      endif
    %}

    {% if has_products %}
      <div class="ai-hero-products-grid-{{ ai_gen_id }}">
        {% for i in (1..4) %}
          {% liquid
            assign product_key = 'product_' | append: i
            assign product = block.settings[product_key]
          %}

          <div class="ai-hero-product-card-{{ ai_gen_id }}" data-product-index="{{ i }}">
            {% if product != blank %}
              <a href="{{ product.url }}" class="ai-hero-product-link-{{ ai_gen_id }}" aria-label="View {{ product.title }}"></a>
              
              <div class="ai-hero-product-image-wrapper-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 800 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="ai-hero-product-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="800"
                    height="800"
                  >
                {% else %}
                  <div class="ai-hero-product-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              <div class="ai-hero-product-info-{{ ai_gen_id }}">
                <h3 class="ai-hero-product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
                <div class="ai-hero-product-price-{{ ai_gen_id }}">{{ product.price | money }}</div>
              </div>
            {% else %}
              <div class="ai-hero-product-image-wrapper-{{ ai_gen_id }}">
                <div class="ai-hero-product-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              </div>
              <div class="ai-hero-product-info-{{ ai_gen_id }}">
                <h3 class="ai-hero-product-title-{{ ai_gen_id }}">Product {{ i }}</h3>
                <div class="ai-hero-product-price-{{ ai_gen_id }}">Select a product</div>
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-hero-empty-state-{{ ai_gen_id }}">
        Select products to showcase in your hero section
      </div>
    {% endif %}
  </div>
</hero-products-{{ ai_gen_id }}>

<script>
  (function() {
    class HeroProducts{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-hero-product-card-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.cards.forEach((card) => {
          card.addEventListener('mouseenter', () => {
            this.cards.forEach((c) => c.classList.remove('active'));
            card.classList.add('active');
          });

          card.addEventListener('mouseleave', () => {
            card.classList.remove('active');
          });
        });
      }
    }

    customElements.define('hero-products-{{ ai_gen_id }}', HeroProducts{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Hero products showcase",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Main product (larger)"
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "Product 2"
    },
    {
      "type": "product",
      "id": "product_3",
      "label": "Product 3"
    },
    {
      "type": "product",
      "id": "product_4",
      "label": "Product 4"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_padding",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Section padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "label": "Gap between products",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Card border radius",
      "default": 8
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "product_title_size",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Product title size",
      "default": 16
    },
    {
      "type": "range",
      "id": "product_price_size",
      "min": 12,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Product price size",
      "default": 14
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#fefefe"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#2f2e2e"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Product title",
      "default": "#2f2e2e"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price",
      "default": "#2f2e2e"
    }
  ],
  "presets": [
    {
      "name": "Hero products showcase"
    }
  ]
}
{% endschema %}
