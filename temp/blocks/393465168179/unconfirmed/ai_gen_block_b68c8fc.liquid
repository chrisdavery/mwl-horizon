          id="feedback-comments-{{ ai_gen_id }}"
          name="contact[{{ block.settings.textarea_label }}]"
          class="ai-feedback-form__textarea-{{ ai_gen_id }}"
          placeholder="{{ block.settings.textarea_placeholder }}"
          rows="5"
        ></textarea>
      </div>

