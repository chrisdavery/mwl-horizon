        <div class="ai-feedback-form__rating-display-{{ ai_gen_id }}" data-rating-display></div>
      </div>

      <div class="ai-feedback-form__field-{{ ai_gen_id }}">
        <label for="feedback-comments-{{ ai_gen_id }}" class="ai-feedback-form__label-{{ ai_gen_id }}">
          {{ block.settings.textarea_label }}
