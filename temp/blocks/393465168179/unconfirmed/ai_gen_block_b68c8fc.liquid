{% doc %}
  @prompt
    please create me a feedback form, with the first option being a drown down field, the second being a star rating out of 10 and the third a blank field , please add 6 more text fields, please add a drop down field to the bottom, please finish with a name field at the bottom, make heading smaller to 14px, ability to change font
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-feedback-form-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 100%;
  }

  .ai-feedback-form__container-{{ ai_gen_id }} {
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-feedback-form__heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    margin: 0 0 24px;
    font-size: {{ block.settings.heading_size }}px;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
  }

  .ai-feedback-form__field-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-feedback-form__label-{{ ai_gen_id }} {
    display: block;
    margin-bottom: 8px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.label_size }}px;
    font-weight: 500;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-style: {{ block.settings.body_font.style }};
  }

  .ai-feedback-form__select-{{ ai_gen_id }},
  .ai-feedback-form__textarea-{{ ai_gen_id }},
  .ai-feedback-form__input-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_background }};
    color: {{ block.settings.input_text_color }};
    font-size: 16px;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-style: {{ block.settings.body_font.style }};
  }

  .ai-feedback-form__select-{{ ai_gen_id }}:focus,
  .ai-feedback-form__textarea-{{ ai_gen_id }}:focus,
  .ai-feedback-form__input-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.primary_color }};
    outline-offset: 2px;
  }

  .ai-feedback-form__textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
  }

  .ai-feedback-form__stars-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .ai-feedback-form__star-{{ ai_gen_id }} {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    transition: transform 0.2s ease;
  }

  .ai-feedback-form__star-{{ ai_gen_id }}:hover {
    transform: scale(1.1);
  }

  .ai-feedback-form__star-{{ ai_gen_id }} svg {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_inactive_color }};
    transition: fill 0.2s ease;
  }

  .ai-feedback-form__star-{{ ai_gen_id }}.active svg {
    fill: {{ block.settings.star_active_color }};
  }

  .ai-feedback-form__rating-display-{{ ai_gen_id }} {
    margin-top: 8px;
    color: {{ block.settings.text_color }};
    font-size: 14px;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
  }

  .ai-feedback-form__button-{{ ai_gen_id }} {
    width: 100%;
    padding: 14px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.3s ease;
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-style: {{ block.settings.button_font.style }};
  }

  .ai-feedback-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-feedback-form__success-{{ ai_gen_id }},
  .ai-feedback-form__error-{{ ai_gen_id }} {
    margin-top: 16px;
    padding: 12px 16px;
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 14px;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
  }

  .ai-feedback-form__success-{{ ai_gen_id }} {
    background-color: {{ block.settings.success_bg_color }};
    color: {{ block.settings.success_text_color }};
  }

  .ai-feedback-form__error-{{ ai_gen_id }} {
    background-color: {{ block.settings.error_bg_color }};
    color: {{ block.settings.error_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-feedback-form__container-{{ ai_gen_id }} {
      padding: {{ block.settings.padding | times: 0.7 }}px;
    }

    .ai-feedback-form__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<feedback-form-{{ ai_gen_id }} class="ai-feedback-form-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
