{% doc %}
  @prompt
    A section with three horizontal blocks, each block needs a header, address field, phone number field, email field and a book now button, remove box line around all three boxes, remove words address, phone and email , add additional button under book now button for all three blocks, make button smaller in width, add underline option under email field, add line under email field without hover, section needs to fill page for desktop view, option to fill page, align location blocks to the centre, section to be full width
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-location-blocks-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-location-blocks-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.gap }}px;
    max-width: 100%;
    padding: 0 40px;
  }

  .ai-location-block-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    padding: {{ block.settings.card_padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .ai-location-block-header-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.spacing }}px;
    font-size: {{ block.settings.heading_size }}px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ai-location-block-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.spacing }}px;
    margin-bottom: {{ block.settings.spacing }}px;
    width: 100%;
  }

  .ai-location-block-field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-location-block-field-{{ ai_gen_id }}:last-child {
    padding-bottom: {{ block.settings.spacing }}px;
    border-bottom: {{ block.settings.divider_width }}px solid {{ block.settings.divider_color }};
  }

  .ai-location-block-value-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  .ai-location-block-value-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: {% if block.settings.underline_links %}underline{% else %}none{% endif %};
  }

  .ai-location-block-value-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-location-block-buttons-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: center;
  }

  .ai-location-block-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 10px 24px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
  }

  .ai-location-block-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text }};
    border-color: {{ block.settings.button_hover_border }};
  }

  .ai-location-block-button-secondary-{{ ai_gen_id }} {
    display: inline-block;
    padding: 10px 24px;
    background-color: {{ block.settings.button_2_background }};
    color: {{ block.settings.button_2_text }};
    text-decoration: none;
    border-radius: {{ block.settings.button_2_border_radius }}px;
    font-size: {{ block.settings.button_2_text_size }}px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.3s ease;
    border: {{ block.settings.button_2_border_width }}px solid {{ block.settings.button_2_border_color }};
  }

  .ai-location-block-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_2_hover_background }};
    color: {{ block.settings.button_2_hover_text }};
    border-color: {{ block.settings.button_2_hover_border }};
  }

  @media screen and (max-width: 989px) {
    .ai-location-blocks-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.gap | times: 0.75 }}px;
      padding: 0 20px;
    }

    .ai-location-block-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.75 }}px;
    }
  }
{% endstyle %}

<div class="ai-location-blocks-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-location-blocks-container-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign heading_key = 'location_' | append: i | append: '_heading'
        assign address_key = 'location_' | append: i | append: '_address'
        assign phone_key = 'location_' | append: i | append: '_phone'
        assign email_key = 'location_' | append: i | append: '_email'
        assign button_text_key = 'location_' | append: i | append: '_button_text'
        assign button_link_key = 'location_' | append: i | append: '_button_link'
        assign button_2_text_key = 'location_' | append: i | append: '_button_2_text'
        assign button_2_link_key = 'location_' | append: i | append: '_button_2_link'

        assign heading = block.settings[heading_key]
        assign address = block.settings[address_key]
        assign phone = block.settings[phone_key]
        assign email = block.settings[email_key]
        assign button_text = block.settings[button_text_key]
        assign button_link = block.settings[button_link_key]
        assign button_2_text = block.settings[button_2_text_key]
        assign button_2_link = block.settings[button_2_link_key]
      %}

      <div class="ai-location-block-{{ ai_gen_id }}">
        {% if heading != blank %}
          <h3 class="ai-location-block-header-{{ ai_gen_id }}">{{ heading }}</h3>
        {% endif %}

        <div class="ai-location-block-info-{{ ai_gen_id }}">
          {% if address != blank %}
            <div class="ai-location-block-field-{{ ai_gen_id }}">
              <div class="ai-location-block-value-{{ ai_gen_id }}">{{ address }}</div>
            </div>
          {% endif %}

          {% if phone != blank %}
            <div class="ai-location-block-field-{{ ai_gen_id }}">
              <div class="ai-location-block-value-{{ ai_gen_id }}">
                <a href="tel:{{ phone | replace: ' ', '' | replace: '(', '' | replace: ')', '' | replace: '-', '' }}">{{ phone }}</a>
              </div>
            </div>
          {% endif %}

          {% if email != blank %}
            <div class="ai-location-block-field-{{ ai_gen_id }}">
              <div class="ai-location-block-value-{{ ai_gen_id }}">
                <a href="mailto:{{ email }}">{{ email }}</a>
              </div>
            </div>
          {% endif %}
        </div>

        <div class="ai-location-block-buttons-{{ ai_gen_id }}">
          {% if button_text != blank and button_link != blank %}
            <a href="{{ button_link }}" class="ai-location-block-button-{{ ai_gen_id }}">
              {{ button_text }}
            </a>
          {% endif %}

          {% if button_2_text != blank and button_2_link != blank %}
            <a href="{{ button_2_link }}" class="ai-location-block-button-secondary-{{ ai_gen_id }}">
              {{ button_2_text }}
            </a>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

