    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Background",
      "default": "#2f2e2e"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Border",
      "default": "#2f2e2e"
