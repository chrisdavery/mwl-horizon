{% doc %}
  @prompt
    A section with three horizontal blocks, each block needs a header, address field, email field and a book now button, remove box line around all three boxes, remove words address, phone and email, add additional button under book now button for all three blocks, make button smaller in width, add underline option under email field, add line under email field without hover, section needs to fill page for desktop view and needs to sit centred on mobile view
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-appointment-blocks-{{ ai_gen_id }} {
    width: 100%;
    padding: 40px 20px;
  }

  .ai-appointment-blocks__container-{{ ai_gen_id }} {
    display: flex;
    gap: 40px;
    max-width: 100%;
    justify-content: center;
    align-items: stretch;
  }

  .ai-appointment-block-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 400px;
  }

  .ai-appointment-block__header-{{ ai_gen_id }} {
    font-size: {{ block.settings.header_size }}px;
    color: {{ block.settings.header_color }};
    margin: 0;
    text-align: {{ block.settings.text_alignment }};
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ai-appointment-block__address-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-appointment-block__email-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-appointment-block__email-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.email_color }};
    text-decoration: {% if block.settings.email_underline %}underline{% else %}none{% endif %};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-appointment-block__email-line-{{ ai_gen_id }} {
    width: 100%;
    height: 1px;
    background-color: {{ block.settings.line_color }};
  }

  .ai-appointment-block__buttons-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: {% if block.settings.text_alignment == 'center' %}center{% elsif block.settings.text_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
  }

  .ai-appointment-block__button-{{ ai_gen_id }} {
    padding: 12px 24px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    text-decoration: none;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    width: {{ block.settings.button_width }}px;
    text-align: center;
    display: inline-block;
  }

  .ai-appointment-block__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-appointment-blocks__container-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: center;
      gap: 60px;
    }

    .ai-appointment-block-{{ ai_gen_id }} {
      max-width: 500px;
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-appointment-blocks-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-appointment-blocks__container-{{ ai_gen_id }}">
    <div class="ai-appointment-block-{{ ai_gen_id }}">
      {% if block.settings.header_1 != blank %}
        <h3 class="ai-appointment-block__header-{{ ai_gen_id }}">{{ block.settings.header_1 }}</h3>
      {% endif %}

      {% if block.settings.address_1 != blank %}
        <div class="ai-appointment-block__address-{{ ai_gen_id }}">{{ block.settings.address_1 }}</div>
      {% endif %}

      <div class="ai-appointment-block__email-wrapper-{{ ai_gen_id }}">
        {% if block.settings.email_1 != blank %}
          <a href="mailto:{{ block.settings.email_1 }}" class="ai-appointment-block__email-{{ ai_gen_id }}">
            {{ block.settings.email_1 }}
          </a>
        {% endif %}
        <div class="ai-appointment-block__email-line-{{ ai_gen_id }}"></div>
      </div>

      <div class="ai-appointment-block__buttons-{{ ai_gen_id }}">
        {% if block.settings.button_1_link != blank %}
          <a href="{{ block.settings.button_1_link }}" class="ai-appointment-block__button-{{ ai_gen_id }}">
            {{ block.settings.button_1_text }}
          </a>
        {% endif %}
        {% if block.settings.button_2_link != blank %}
          <a href="{{ block.settings.button_2_link }}" class="ai-appointment-block__button-{{ ai_gen_id }}">
            {{ block.settings.button_2_text }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="ai-appointment-block-{{ ai_gen_id }}">
      {% if block.settings.header_2 != blank %}
        <h3 class="ai-appointment-block__header-{{ ai_gen_id }}">{{ block.settings.header_2 }}</h3>
      {% endif %}

      {% if block.settings.address_2 != blank %}
        <div class="ai-appointment-block__address-{{ ai_gen_id }}">{{ block.settings.address_2 }}</div>
      {% endif %}

      <div class="ai-appointment-block__email-wrapper-{{ ai_gen_id }}">
        {% if block.settings.email_2 != blank %}
          <a href="mailto:{{ block.settings.email_2 }}" class="ai-appointment-block__email-{{ ai_gen_id }}">
            {{ block.settings.email_2 }}
          </a>
        {% endif %}
        <div class="ai-appointment-block__email-line-{{ ai_gen_id }}"></div>
      </div>

      <div class="ai-appointment-block__buttons-{{ ai_gen_id }}">
        {% if block.settings.button_1_link != blank %}
          <a href="{{ block.settings.button_1_link }}" class="ai-appointment-block__button-{{ ai_gen_id }}">
            {{ block.settings.button_1_text }}
          </a>
        {% endif %}
        {% if block.settings.button_2_link != blank %}
          <a href="{{ block.settings.button_2_link }}" class="ai-appointment-block__button-{{ ai_gen_id }}">
            {{ block.settings.button_2_text }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="ai-appointment-block-{{ ai_gen_id }}">
      {% if block.settings.header_3 != blank %}
        <h3 class="ai-appointment-block__header-{{ ai_gen_id }}">{{ block.settings.header_3 }}</h3>
      {% endif %}

      {% if block.settings.address_3 != blank %}
        <div class="ai-appointment-block__address-{{ ai_gen_id }}">{{ block.settings.address_3 }}</div>
      {% endif %}

      <div class="ai-appointment-block__email-wrapper-{{ ai_gen_id }}">
        {% if block.settings.email_3 != blank %}
          <a href="mailto:{{ block.settings.email_3 }}" class="ai-appointment-block__email-{{ ai_gen_id }}">
            {{ block.settings.email_3 }}
          </a>
        {% endif %}
        <div class="ai-appointment-block__email-line-{{ ai_gen_id }}"></div>
      </div>

      <div class="ai-appointment-block__buttons-{{ ai_gen_id }}">
        {% if block.settings.button_1_link != blank %}
          <a href="{{ block.settings.button_1_link }}" class="ai-appointment-block__button-{{ ai_gen_id }}">
            {{ block.settings.button_1_text }}
          </a>
        {% endif %}
        {% if block.settings.button_2_link != blank %}
          <a href="{{ block.settings.button_2_link }}" class="ai-appointment-block__button-{{ ai_gen_id }}">
            {{ block.settings.button_2_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Appointment blocks",
  "settings": [
    {
      "type": "header",
      "content": "Block 1"
    },
    {
      "type": "text",
      "id": "header_1",
      "label": "Header",
      "default": "Location 1"
    },
    {
      "type": "textarea",
      "id": "address_1",
      "label": "Address",
      "default": "123 Main Street\nCity, State 12345"
    },
    {
      "type": "text",
      "id": "email_1",
      "label": "Email",
      "default": "location1@example.com"
    },
    {
      "type": "header",
      "content": "Block 2"
    },
    {
      "type": "text",
      "id": "header_2",
      "label": "Header",
      "default": "Location 2"
    },
    {
      "type": "textarea",
      "id": "address_2",
      "label": "Address",
      "default": "456 Oak Avenue\nCity, State 12345"
    },
    {
      "type": "text",
      "id": "email_2",
      "label": "Email",
      "default": "location2@example.com"
    },
    {
      "type": "header",
      "content": "Block 3"
    },
    {
      "type": "text",
      "id": "header_3",
      "label": "Header",
      "default": "Location 3"
    },
    {
      "type": "textarea",
      "id": "address_3",
      "label": "Address",
      "default": "789 Pine Road\nCity, State 12345"
    },
    {
      "type": "text",
      "id": "email_3",
      "label": "Email",
      "default": "location3@example.com"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_1_text",
      "label": "Button 1 text",
      "default": "Book now"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Button 1 link"
    },
    {
      "type": "text",
      "id": "button_2_text",
      "label": "Button 2 text",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Button 2 link"
