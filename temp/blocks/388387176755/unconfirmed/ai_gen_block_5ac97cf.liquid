      "id": "header_size",
      "min": 14,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Header size",
      "default": 20
    },
    {
      "type": "color",
      "id": "header_color",
      "label": "Header color",
      "default": "#2f2e2e"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text size",
