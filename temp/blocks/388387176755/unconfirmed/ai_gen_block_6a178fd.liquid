{% doc %}
  @prompt
    A section with two horizontal blocks, each block needs a header, address field, phone number field, email field and a book now button, remove box line around all three boxes, remove words address, phone and email , add additional button under book now button for all three blocks, make button smaller in width, add underline option under email field, add line under email field without hover, section needs to fill page for desktop view, option to fill page
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-locations-section-{{ ai_gen_id }} {
    {% if block.settings.full_width %}
      width: 100%;
      max-width: 100%;
      padding: 0;
    {% else %}
      max-width: 1200px;
      margin: 0 auto;
      padding: 40px 20px;
    {% endif %}
  }

  .ai-locations-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px;
    {% if block.settings.full_width %}
      padding: 60px 40px;
    {% endif %}
  }

  .ai-location-block-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-location-header-{{ ai_gen_id }} {
    font-size: {{ block.settings.header_size }}px;
    color: {{ block.settings.header_color }};
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .ai-location-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-location-field-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-location-email-{{ ai_gen_id }} {
    color: {{ block.settings.email_color }};
    text-decoration: none;
    {% if block.settings.email_underline %}
      text-decoration: underline;
    {% endif %}
    border-bottom: {{ block.settings.email_line_width }}px solid {{ block.settings.email_line_color }};
    padding-bottom: 2px;
    display: inline-block;
  }

  .ai-location-buttons-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 8px;
  }

  .ai-location-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    text-align: center;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.3s ease;
    width: {{ block.settings.button_width }}%;
  }

  .ai-location-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 768px) {
    .ai-locations-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
      {% if block.settings.full_width %}
        padding: 40px 20px;
      {% endif %}
    }

    .ai-location-button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-locations-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-locations-container-{{ ai_gen_id }}">
    <div class="ai-location-block-{{ ai_gen_id }}">
      {% if block.settings.location_1_header != blank %}
        <h3 class="ai-location-header-{{ ai_gen_id }}">{{ block.settings.location_1_header }}</h3>
      {% endif %}
      
      <div class="ai-location-info-{{ ai_gen_id }}">
        {% if block.settings.location_1_address != blank %}
          <div class="ai-location-field-{{ ai_gen_id }}">{{ block.settings.location_1_address }}</div>
        {% endif %}
        
        {% if block.settings.location_1_phone != blank %}
          <div class="ai-location-field-{{ ai_gen_id }}">{{ block.settings.location_1_phone }}</div>
        {% endif %}
        
        {% if block.settings.location_1_email != blank %}
          <a href="mailto:{{ block.settings.location_1_email }}" class="ai-location-email-{{ ai_gen_id }}">
            {{ block.settings.location_1_email }}
          </a>
        {% endif %}
      </div>

      <div class="ai-location-buttons-{{ ai_gen_id }}">
        {% if block.settings.location_1_button_1_text != blank %}
          <a href="{{ block.settings.location_1_button_1_link }}" class="ai-location-button-{{ ai_gen_id }}">
            {{ block.settings.location_1_button_1_text }}
          </a>
        {% endif %}
        
        {% if block.settings.location_1_button_2_text != blank %}
          <a href="{{ block.settings.location_1_button_2_link }}" class="ai-location-button-{{ ai_gen_id }}">
            {{ block.settings.location_1_button_2_text }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="ai-location-block-{{ ai_gen_id }}">
      {% if block.settings.location_2_header != blank %}
        <h3 class="ai-location-header-{{ ai_gen_id }}">{{ block.settings.location_2_header }}</h3>
      {% endif %}
      
      <div class="ai-location-info-{{ ai_gen_id }}">
        {% if block.settings.location_2_address != blank %}
          <div class="ai-location-field-{{ ai_gen_id }}">{{ block.settings.location_2_address }}</div>
        {% endif %}
        
        {% if block.settings.location_2_phone != blank %}
          <div class="ai-location-field-{{ ai_gen_id }}">{{ block.settings.location_2_phone }}</div>
        {% endif %}
        
        {% if block.settings.location_2_email != blank %}
          <a href="mailto:{{ block.settings.location_2_email }}" class="ai-location-email-{{ ai_gen_id }}">
            {{ block.settings.location_2_email }}
          </a>
        {% endif %}
      </div>

      <div class="ai-location-buttons-{{ ai_gen_id }}">
        {% if block.settings.location_2_button_1_text != blank %}
          <a href="{{ block.settings.location_2_button_1_link }}" class="ai-location-button-{{ ai_gen_id }}">
            {{ block.settings.location_2_button_1_text }}
          </a>
        {% endif %}
        
        {% if block.settings.location_2_button_2_text != blank %}
          <a href="{{ block.settings.location_2_button_2_link }}" class="ai-location-button-{{ ai_gen_id }}">
            {{ block.settings.location_2_button_2_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

