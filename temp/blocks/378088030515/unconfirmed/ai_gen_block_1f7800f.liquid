{% doc %}
  @prompt
    Create a responsive section that displays content in a 3-column layout with customizable buttons. The section should allow merchants to add multiple buttons with customizable text, links, and styling. Include settings for button colors, text, and destinations. Make it mobile-responsive so it stacks nicely on smaller screens., Please make it page wide

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-button-grid-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    width: 100%;
  }

  .ai-button-grid__container-{{ ai_gen_id }} {
    width: 100%;
    padding: 0 20px;
  }

  .ai-button-grid__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-button-grid__title-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px;
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-button-grid__subtitle-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    margin: 0;
    font-size: {{ block.settings.text_size }}px;
  }

  .ai-button-grid__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.button_spacing }}px;
    align-items: start;
  }

  .ai-button-grid__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .ai-button-grid__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    transition: all 0.3s ease;
    cursor: pointer;
    min-height: 48px;
    width: 100%;
    margin-bottom: 16px;
  }

  .ai-button-grid__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: translateY(-2px);
  }

  .ai-button-grid__button-description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: 14px;
    line-height: 1.4;
    margin: 0;
  }

  .ai-button-grid__empty-state-{{ ai_gen_id }} {
    grid-column: 1 / -1;
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
  }

  @media screen and (max-width: 990px) {
    .ai-button-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-button-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.button_spacing | times: 0.75 }}px;
    }

    .ai-button-grid__container-{{ ai_gen_id }} {
      padding: 0 16px;
    }

    .ai-button-grid__header-{{ ai_gen_id }} {
      margin-bottom: 30px;
    }

    .ai-button-grid__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-button-grid__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-button-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-button-grid__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subtitle != blank %}
      <div class="ai-button-grid__header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-button-grid__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <div class="ai-button-grid__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
        {% endif %}
      </div>
    {% endif %}<div class="ai-button-grid__grid-{{ ai_gen_id }}">
      {% assign has_buttons = false %}
      
      {% for i in (1..9) %}
        {% liquid
          assign button_text_key = 'button_' | append: i | append: '_text'
          assign button_link_key = 'button_' | append: i | append: '_link'
          assign button_description_key = 'button_' | append: i | append: '_description'
          
          assign button_text = block.settings[button_text_key]
          assign button_link = block.settings[button_link_key]
          assign button_description = block.settings[button_description_key]%}

        {% if button_text != blank %}
          {% assign has_buttons = true %}
          <div class="ai-button-grid__item-{{ ai_gen_id }}">
            {% if button_link != blank %}
              <a href="{{ button_link }}" class="ai-button-grid__button-{{ ai_gen_id }}">
                {{ button_text }}
              </a>
            {% else %}
              <span class="ai-button-grid__button-{{ ai_gen_id }}" style="cursor: default;">
                {{ button_text }}
              </span>
            {% endif %}
            {% if button_description != blank %}
              <p class="ai-button-grid__button-description-{{ ai_gen_id }}">{{ button_description }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}

      {% unless has_buttons %}
        <div class="ai-button-grid__empty-state-{{ ai_gen_id }}">
          <p>Add button text to get started with your button grid</p>
        </div>
      {% endunless %}
    </div>
  </div>
</div>

