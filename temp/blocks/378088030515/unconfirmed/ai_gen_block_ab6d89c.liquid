{% doc %}
  @prompt
    Create a three-column section with icons, headings, descriptions, and buttons similar to the provided image. Each column should have: a circular decorative icon at the top, a heading, descriptive text below, and a customizable button at the bottom. Include settings for merchants to customize the icon, heading text, description text, button text, and button links for each column. Make it mobile-responsive so columns stack vertically on smaller screens. Style the buttons with a dark background and white text to match the design shown.

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-three-column-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;background-color: {{ block.settings.background_color }};
  }

  .ai-three-column-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-three-column-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.column_gap }}px;
  }

  .ai-three-column-item-{{ ai_gen_id }} {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .ai-three-column-icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.icon_background_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: {{ block.settings.icon_margin_bottom }}px;
    flex-shrink: 0;
  }

  .ai-three-column-icon-{{ ai_gen_id }} {
    width: calc({{ block.settings.icon_size }}px * 0.5);
    height: calc({{ block.settings.icon_size }}px * 0.5);
    color: {{ block.settings.icon_color }};
  }

  .ai-three-column-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .ai-three-column-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin:0 0 {{ block.settings.heading_margin_bottom }}px;
    font-weight: 600;
  }

  .ai-three-column-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0 0 {{ block.settings.description_margin_bottom }}px;
    flex-grow: 1;
  }

  .ai-three-column-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight:500;
    transition: background-color 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-three-column-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 768px) {
    .ai-three-column-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_column_gap }}px;
    }

    .ai-three-column-item-{{ ai_gen_id }} {
      max-width: 400px;
      margin: 0 auto;
    }

    .ai-three-column-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_heading_size }}px;
    }

    .ai-three-column-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_description_size }}px;
    }
  }
{% endstyle %}<div class="ai-three-column-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-three-column-container-{{ ai_gen_id }}">
    <div class="ai-three-column-grid-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign heading_key = 'column_' | append: i | append: '_heading'
          assign description_key = 'column_' | append: i | append: '_description'
          assign button_text_key = 'column_' | append: i | append: '_button_text'
          assign button_link_key = 'column_' | append: i | append: '_button_link'
          assign icon_key = 'column_' | append: i | append: '_icon'

          assign heading = block.settings[heading_key]
          assign description = block.settings[description_key]
          assign button_text = block.settings[button_text_key]
          assign button_link = block.settings[button_link_key]
          assign icon_type = block.settings[icon_key]
        %}

        <div class="ai-three-column-item-{{ ai_gen_id }}">
          <div class="ai-three-column-icon-wrapper-{{ ai_gen_id }}">
            <div class="ai-three-column-icon-{{ ai_gen_id }}">
              {% case icon_type %}
                {% when 'shipping' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="1" y="3" width="15" height="13"></rect>
                    <polygon points="16,8 20,8 23,11 23,16 16,16"></polygon>
                    <circle cx="5.5" cy="18.5" r="2.5"></circle>
                    <circle cx="18.5" cy="18.5" r="2.5"></circle>
                  </svg>
                {% when 'support' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 12l2 2 4-4"></path>
                    <path d="M21 12c.552 0 1-.448 1-1V8c0-.552-.448-1-1-1h-1V6a5 5 0 0 0-10 0v1H9c-.552 0-1 .448-1 1v3c0 .552.448 1 1 1h1v1a5 5 0 0 0 10 0v-1h1z"></path>
                  </svg>
                {% when 'quality' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="12,2 15.09,8.26 22,9 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9 8.91,8.26"></polygon>
                  </svg>
                {% when 'returns' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="1,4 1,10 7,10"></polyline>
                    <path d="M3.5115a9 9 0 1 0 2.13-9.36L1 10"></path>
                  </svg>
                {% when 'security' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                  </svg>
                {% when 'heart' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                  </svg>
                {% else %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="12,2 15.09,8.26 22,9 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9 8.91,8.26"></polygon>
                  </svg>
              {% endcase %}
            </div>
          </div>

          {% if heading != blank %}
            <h3 class="ai-three-column-heading-{{ ai_gen_id }}">{{ heading }}</h3>
          {% endif %}

          {% if description != blank %}
            <div class="ai-three-column-description-{{ ai_gen_id }}">{{ description }}</div>
          {% endif %}

          {% if button_text != blank %}
            <a 
              href="{{ button_link | default: '#' }}" 
              class="ai-three-column-button-{{ ai_gen_id }}"
            >
              {{ button_text }}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

