{% doc %}
  @prompt
    I need a product gallery showcasing 4 clickable images from left to right
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-gallery-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-product-gallery__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-product-gallery__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.image_gap }}px;
  }

  .ai-product-gallery__item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
  }

  .ai-product-gallery__link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    text-decoration: none;
  }

  .ai-product-gallery__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .ai-product-gallery__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-product-gallery__link-{{ ai_gen_id }}:hover .ai-product-gallery__image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-product-gallery__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-product-gallery__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-product-gallery__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    font-size: 12px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-product-gallery__overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent);
    padding: 20px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ai-product-gallery__link-{{ ai_gen_id }}:hover .ai-product-gallery__overlay-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-product-gallery__title-{{ ai_gen_id }} {
    color: #ffffff;
    font-size: 16px;
    font-weight: 600;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  @media screen and (max-width: 989px) {
    .ai-product-gallery__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-product-gallery__grid-{{ ai_gen_id }} {
      gap: {{ block.settings.image_gap | times: 0.5 }}px;
    }

    .ai-product-gallery__title-{{ ai_gen_id }} {
      font-size: 14px;
    }
  }
{% endstyle %}

<div class="ai-product-gallery-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-gallery__container-{{ ai_gen_id }}">
    <div class="ai-product-gallery__grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign link_key = 'link_' | append: i
          assign title_key = 'title_' | append: i
          
          assign image = block.settings[image_key]
          assign link = block.settings[link_key]
          assign title = block.settings[title_key]
        %}
        
        <div class="ai-product-gallery__item-{{ ai_gen_id }}">
          {% if link != blank %}
            <a href="{{ link }}" class="ai-product-gallery__link-{{ ai_gen_id }}">
          {% else %}
            <div class="ai-product-gallery__link-{{ ai_gen_id }}">
          {% endif %}
            
            <div class="ai-product-gallery__image-wrapper-{{ ai_gen_id }}">
              {% if image %}
                <img
                  src="{{ image | image_url: width: 800 }}"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                  class="ai-product-gallery__image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-product-gallery__placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                  <div class="ai-product-gallery__empty-state-{{ ai_gen_id }}">
                    Add image {{ i }}
                  </div>
                </div>
              {% endif %}
            </div>

            {% if title != blank and image %}
              <div class="ai-product-gallery__overlay-{{ ai_gen_id }}">
                <h3 class="ai-product-gallery__title-{{ ai_gen_id }}">{{ title }}</h3>
              </div>
            {% endif %}

          {% if link != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product gallery",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Section padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "image_gap",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Gap between images",
      "default": 16
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        {
          "value": "1 / 1",
          "label": "Square (1:1)"
        },
        {
          "value": "3 / 4",
          "label": "Portrait (3:4)"
        },
        {
          "value": "4 / 5",
          "label": "Portrait (4:5)"
        },
