{% doc %}
  @prompt
    a review footer with one review per slide, remove box around review, remove circles around arrows, remove page dots
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-review-footer-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
  }

  .ai-review-footer-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-review-footer-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-review-footer-title-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 12px;
  }

  .ai-review-footer-subtitle-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.subtitle_size }}px;
    margin: 0;
  }

  .ai-review-footer-slider-wrapper-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-review-footer-slider-{{ ai_gen_id }} {
    display: flex;
    overflow: hidden;
    position: relative;
  }

  .ai-review-footer-track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease;
    width: 100%;
  }

  .ai-review-footer-slide-{{ ai_gen_id }} {
    min-width: 100%;
    flex-shrink: 0;
    padding: 0 10px;
  }

  .ai-review-footer-card-{{ ai_gen_id }} {
    padding: 40px 30px;
    text-align: center;
  }

  .ai-review-footer-stars-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 4px;
    margin-bottom: 20px;
  }

  .ai-review-footer-star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_color }};
  }

  .ai-review-footer-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.review_text_size }}px;
    line-height: 1.6;
    margin: 0 0 20px;
  }

  .ai-review-footer-author-{{ ai_gen_id }} {
    color: {{ block.settings.author_color }};
    font-size: {{ block.settings.author_size }}px;
    font-weight: 600;
    margin: 0;
  }

  .ai-review-footer-controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: 30px;
  }

  .ai-review-footer-nav-{{ ai_gen_id }} {
    background: none;
    border: none;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: opacity 0.3s ease;
  }

  .ai-review-footer-nav-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-review-footer-nav-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-review-footer-nav-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
    stroke: {{ block.settings.nav_icon_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-review-footer-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.6 }}px 0 {{ block.settings.padding_bottom | times: 0.6 }}px;
    }

    .ai-review-footer-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-review-footer-card-{{ ai_gen_id }} {
      padding: 30px 20px;
    }
  }
{% endstyle %}

<review-slider-{{ ai_gen_id }}
  class="ai-review-footer-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-review-footer-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subtitle != blank %}
      <div class="ai-review-footer-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-review-footer-title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <p class="ai-review-footer-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-review-footer-slider-wrapper-{{ ai_gen_id }}">
      <div class="ai-review-footer-slider-{{ ai_gen_id }}">
        <div class="ai-review-footer-track-{{ ai_gen_id }}" data-track>
          {% for i in (1..5) %}
            {% liquid
              assign review_text_key = 'review_' | append: i | append: '_text'
              assign review_author_key = 'review_' | append: i | append: '_author'
              assign review_rating_key = 'review_' | append: i | append: '_rating'
              
              assign review_text = block.settings[review_text_key]
              assign review_author = block.settings[review_author_key]
              assign review_rating = block.settings[review_rating_key]
            %}

            {% if review_text != blank %}
              <div class="ai-review-footer-slide-{{ ai_gen_id }}">
                <div class="ai-review-footer-card-{{ ai_gen_id }}">
                  <div class="ai-review-footer-stars-{{ ai_gen_id }}">
                    {% for star in (1..5) %}
                      <svg
                        class="ai-review-footer-star-{{ ai_gen_id }}"
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        {% if star <= review_rating %}
                          fill="currentColor"
                        {% else %}
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                        {% endif %}
                      >
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                    {% endfor %}
                  </div>
                  <p class="ai-review-footer-text-{{ ai_gen_id }}">{{ review_text }}</p>
                  {% if review_author != blank %}
                    <p class="ai-review-footer-author-{{ ai_gen_id }}">{{ review_author }}</p>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <div class="ai-review-footer-controls-{{ ai_gen_id }}">
        <button
          class="ai-review-footer-nav-{{ ai_gen_id }}"
          data-prev
          aria-label="Previous review"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>

        <button
          class="ai-review-footer-nav-{{ ai_gen_id }}"
          data-next
          aria-label="Next review"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</review-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class ReviewSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.totalSlides = 0;
      }

      connectedCallback() {
        this.track = this.querySelector('[data-track]');
        this.slides = this.querySelectorAll('.ai-review-footer-slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('[data-prev]');
        this.nextButton = this.querySelector('[data-next]');
        
        this.totalSlides = this.slides.length;
        
        if (this.totalSlides === 0) return;
        
        this.updateSlider();
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.prevSlide());
        this.nextButton.addEventListener('click', () => this.nextSlide());
      }

      updateSlider() {
        const offset = -this.currentSlide * 100;
        this.track.style.transform = 'translateX(' + offset + '%)';
        
        this.prevButton.disabled = this.currentSlide === 0;
        this.nextButton.disabled = this.currentSlide === this.totalSlides - 1;
      }

      prevSlide() {
        if (this.currentSlide > 0) {
          this.currentSlide--;
          this.updateSlider();
        }
      }

      nextSlide() {
        if (this.currentSlide < this.totalSlides - 1) {
          this.currentSlide++;
          this.updateSlider();
        }
      }
    }

    customElements.define('review-slider-{{ ai_gen_id }}', ReviewSlider{{ ai_gen_id }});
  })();
</script>

