<!-- sections/booking-embed-perth.liquid -->
{% if section.settings.embed_code != blank %}
  <div class="booking-embed-container py-8 px-4 md:px-8 max-w-screen-lg mx-auto">
    {{ section.settings.embed_code}}
  </div>



{% else %}
  <div class="text-center py-8 text-gray-500">
    No embed code provided. Please add your booking iframe in the section settings.
  </div>
{% endif %}

{% schema %}
{
  "name": "Booking Embed Perth",
  "tag": "section",
  "settings": [
    {
      "type": "textarea",
      "id": "embed_code",
      "label": "Booking Embed Code",
      "default": "<iframe src=\"https://app.acuityscheduling.com/schedule.php?owner=34568228&ref=embedded_csp\" title=\"Schedule Appointment\" width=\"100%\" height=\"800\" frameborder=\"0\" style=\"margin-top: 70px;\" allow=\"payment\"></iframe><script src=\"https://embed.acuityscheduling.com/js/embed.js\" type=\"text/javascript\"></script>"
    }
  ],
  "presets": [
    {
      "name": "Booking Embed Perth"
    }
  ]
}
{% endschema %}