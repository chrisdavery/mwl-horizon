<div class="acuity-wrapper" style="text-align:center;">
  {% render 'booking-source-to-acuity' %}
  <div class="acuity-product-grid">

    {% assign target_collection = collections['dress-selection'] %}

    {% if target_collection != blank %}
      {% paginate target_collection.products by 100 %}
        {% for product in target_collection.products %}
          {% assign first_image = product.featured_image | img_url: '308x486' %}

          <div class="acuity-item" data-f-price="{{ product.price }}">
            <input
              id="acuity-{{ product.handle }}"
              name="field:7618076"
              type="checkbox"
              value="{{ product.title }}"
            >

            <label for="acuity-{{ product.handle }}">
              <img
                loading="lazy"
                src="{{ first_image | prepend: 'https:' }}"
                alt="{{ product.title }}"
                width="154"
                height="243"
              >

              <span class="acuity-pd-title">
                {{ product.title }}
              </span>

              <div class="acuity-pd-price">
                {{ product.price | money_with_currency }}
              </div>
            </label>
          </div>

        {% endfor %}
      {% endpaginate %}
    {% else %}
      <p>Dress Selection collection not found.</p>
    {% endif %}

  </div>

  <div class="acuity-button-container">
    <button
      id="acuityContinueBtn"
      class="acuity-btn-continue"
      style="margin-top:20px;padding:10px 20px;border:0;margin-bottom:3em;"
    >
      CONTINUE
    </button>
  </div>

  <div class="acuity-booking-frame" style="display:none;">
    <iframe
      id="acuityIframe"
      src="https://app.acuityscheduling.com/schedule/6f1d26e5/"
      title="Schedule Appointment"
      width="100%"
      height="800"
      frameborder="0"
      style="margin-top:70px;"
    ></iframe>
  </div>
</div>

<script src="https://embed.acuityscheduling.com/js/embed.js" type="text/javascript"></script>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const wrapper = document.querySelector('.acuity-wrapper');
  if (!wrapper) return;

  const checkboxes = wrapper.querySelectorAll('.acuity-item input[type="checkbox"]');
  const maxSelections = 1000;
  const continueBtn = document.getElementById('acuityContinueBtn');
  const iframe = document.getElementById('acuityIframe');
  const productGrid = wrapper.querySelector('.acuity-product-grid');
  const bookingFrame = wrapper.querySelector('.acuity-booking-frame');

  // Read attribution cookie and get all values
const getAttributionData = () => {
  try {
    const match = document.cookie.match(/(?:^|; )mwl_attribution=([^;]+)/);
    if (!match) return {};

    const data = JSON.parse(decodeURIComponent(match[1]));

    return {
      tracking_id: data.tracking_id || '',
      utm_source: data.utm_source || '',
      utm_medium: data.utm_medium || '',
      utm_campaign: data.utm_campaign || '',
      utm_content: data.utm_content || '',
      utm_term: data.utm_term || '',
      gclid: data.gclid || '',
      ttclid: data.ttclid || '',
      epik: data.epik || '',
      fbc: data.fbc || '',
      fbp: data.fbp || ''
    };
  } catch (err) {
    console.warn('Error reading mwl_attribution cookie', err);
    return {};
  }
};

  function updateSelectedClasses() {
    checkboxes.forEach(cb => {
      cb.closest('.acuity-item')
        .classList.toggle('selected', cb.checked);
    });
  }

  function getSelectedItems() {
    return Array.from(checkboxes)
      .filter(cb => cb.checked)
      .map(cb => cb.value);
  }

  checkboxes.forEach(cb => {
    cb.addEventListener('change', function () {
      if (getSelectedItems().length > maxSelections) {
        this.checked = false;
        alert('You can select up to ' + maxSelections + ' option only.');
      }
      updateSelectedClasses();
    });
  });

  continueBtn.addEventListener('click', function (e) {
    e.preventDefault();

    const selectedItems = getSelectedItems();
    if (!selectedItems.length) {
      alert('Please select at least one item.');
      return;
    }

    const encoded = encodeURIComponent(selectedItems.join(', '));
    var match = document.cookie.match(/(?:^|; )booking_source=([^;]+)/);
    var source = match ? decodeURIComponent(match[1]) : "direct";

    // Build iframe URL with all fields
const attribution = getAttributionData();

iframe.src =
  `https://app.acuityscheduling.com/schedule/6f1d26e5?ref=embedded_csp` +
  `&field:15103364=${encoded}` +            // original form fields
  `&field:15103601=${encoded}` +
  `&field:17797660=${encodeURIComponent(attribution.utm_source)}` +
  `&field:17899599=${encodeURIComponent(attribution.utm_medium)}` +
  `&field:17899423=${encodeURIComponent(attribution.utm_campaign)}` +
  `&field:18156998=${encodeURIComponent(attribution.tracking_id)}` +
  `&field:NEW_FIELD_UTM_CONTENT=${encodeURIComponent(attribution.utm_content)}` +
  `&field:NEW_FIELD_UTM_TERM=${encodeURIComponent(attribution.utm_term)}` +
  `&field:NEW_FIELD_GCLID=${encodeURIComponent(attribution.gclid)}` +
  `&field:NEW_FIELD_TTCLID=${encodeURIComponent(attribution.ttclid)}` +
  `&field:NEW_FIELD_EPIK=${encodeURIComponent(attribution.epik)}` +
  `&field:NEW_FIELD_FBC=${encodeURIComponent(attribution.fbc)}` +
  `&field:NEW_FIELD_FBP=${encodeURIComponent(attribution.fbp)}`;

    productGrid.style.display = 'none';
    continueBtn.style.display = 'none';
    bookingFrame.style.display = 'block';

    const instructionSection = document.querySelector('#shopify-section-section_rrEHMb, [id^="shopify-section-"][id*="section_rrEHMb"]');

  if (instructionSection) {
    instructionSection.style.display = 'none';
  } else {
    console.warn('Instruction section not found!');
  }


  });

  updateSelectedClasses();
});
</script>

{% schema %}
{
  "name": "Collection Checkboxes",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Choose collection"
    }
  ],
  "presets": [
    {
      "name": "Collection Checkboxes"
    }
  ]
}
{% endschema %}
