{% doc %}
  @prompt
    A three block section, each block needs a heading, an address field, a phone number field, an email field and a book appointment button
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-appointment-location-{{ ai_gen_id }} {
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-appointment-location__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.spacing }}px;
    font-size: {{ block.settings.heading_size }}px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .ai-appointment-location__info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.spacing }}px;
    margin-bottom: {{ block.settings.spacing | times: 1.5 }}px;
  }

  .ai-appointment-location__item-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    {% if block.settings.text_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.text_alignment == 'right' %}
      justify-content: flex-end;
    {% endif %}
  }

  .ai-appointment-location__icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: {{ block.settings.icon_color }};
    margin-top: 2px;
  }

  .ai-appointment-location__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    margin: 0;
  }

  .ai-appointment-location__link-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .ai-appointment-location__link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-appointment-location__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    font-size: {{ block.settings.button_text_size }}px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .ai-appointment-location__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-appointment-location-{{ ai_gen_id }} {
      padding: {{ block.settings.padding | times: 0.7 }}px;
    }

    .ai-appointment-location__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-appointment-location__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-appointment-location-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h3 class="ai-appointment-location__heading-{{ ai_gen_id }}">
      {{ block.settings.heading }}
    </h3>
  {% endif %}

  <div class="ai-appointment-location__info-{{ ai_gen_id }}">
    {% if block.settings.address != blank %}
      <div class="ai-appointment-location__item-{{ ai_gen_id }}">
        <div class="ai-appointment-location__icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
        </div>
        <p class="ai-appointment-location__text-{{ ai_gen_id }}">
          {{ block.settings.address }}
        </p>
      </div>
    {% endif %}

    {% if block.settings.phone != blank %}
      <div class="ai-appointment-location__item-{{ ai_gen_id }}">
        <div class="ai-appointment-location__icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
          </svg>
        </div>
        <p class="ai-appointment-location__text-{{ ai_gen_id }}">
          <a href="tel:{{ block.settings.phone | replace: ' ', '' }}" class="ai-appointment-location__link-{{ ai_gen_id }}">
            {{ block.settings.phone }}
          </a>
        </p>
      </div>
    {% endif %}

    {% if block.settings.email != blank %}
      <div class="ai-appointment-location__item-{{ ai_gen_id }}">
        <div class="ai-appointment-location__icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
            <polyline points="22,6 12,13 2,6"></polyline>
          </svg>
        </div>
        <p class="ai-appointment-location__text-{{ ai_gen_id }}">
          <a href="mailto:{{ block.settings.email }}" class="ai-appointment-location__link-{{ ai_gen_id }}">
            {{ block.settings.email }}
          </a>
        </p>
      </div>
    {% endif %}
  </div>

  {% if block.settings.button_link != blank %}
    <a href="{{ block.settings.button_link }}" class="ai-appointment-location__button-{{ ai_gen_id }}">
      {{ block.settings.button_text }}
    </a>
  {% endif %}
</div>

{% schema %}
{
  "name": "Appointment location",
  "settings": [
    {
      "type": "header",
      "content": "Location details"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Brisbane Boutique"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Address",
      "default": "123 Queen Street\nBrisbane QLD 4000"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "default": "07 3000 0000"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "default": "appointments@mwlbride.com"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Book Appointment"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "padding",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "spacing",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Spacing",
      "default": 16
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f8f6ef"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#2f2e2e"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#2f2e2e"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icons",
      "default": "#2f2e2e"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover",
      "default": "#a52a2a"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 20
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Background",
      "default": "#2f2e2e"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Border",
      "default": "#2f2e2e"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Hover background",
      "default": "#a52a2a"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_border_color",
      "label": "Hover border",
      "default": "#a52a2a"
    },
    {
      "type": "range",
      "id": "button_border_width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "label": "Border width",
      "default": 0
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 0
    },
    {
      "type": "range",
      "id": "button_text_size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 14
    }
  ],
  "presets": [
    {
      "name": "Appointment location"
    }
  ]
}
{% endschema %}