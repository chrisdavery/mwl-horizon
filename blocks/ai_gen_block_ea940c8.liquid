{% doc %}
  @prompt
    A magazine-style editorial layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-editorial-layout-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 20px;
  }

  .ai-editorial-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-editorial-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-editorial-hero-{{ ai_gen_id }} {
    grid-column: 1 / 9;
    position: relative;
    overflow: hidden;
  }

  .ai-editorial-hero-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-editorial-hero-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 600px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-editorial-hero-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-editorial-hero-content-{{ ai_gen_id }} {
    position: absolute;
    bottom: 40px;
    left: 40px;
    right: 40px;
    color: {{ block.settings.hero_text_color }};
    z-index: 2;
  }

  .ai-editorial-hero-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(to top, rgba(0,0,0,{{ block.settings.overlay_opacity | divided_by: 100.0 }}), transparent);
    z-index: 1;
  }

  .ai-editorial-hero-category-{{ ai_gen_id }} {
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 12px;
    font-weight: 500;
  }

  .ai-editorial-hero-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.hero_title_size }}px;
    line-height: 1.1;
    margin: 0 0 16px 0;
    font-weight: 500;
    letter-spacing: 1px;
  }

  .ai-editorial-hero-excerpt-{{ ai_gen_id }} {
    font-size: 16px;
    line-height: 1.5;
    margin: 0;
    max-width: 600px;
  }

  .ai-editorial-sidebar-{{ ai_gen_id }} {
    grid-column: 9 / 13;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-editorial-card-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    background-color: {{ block.settings.card_background }};
  }

  .ai-editorial-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 280px;
    object-fit: cover;
    display: block;
  }

  .ai-editorial-card-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 280px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-editorial-card-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-editorial-card-content-{{ ai_gen_id }} {
    padding: 24px;
  }

  .ai-editorial-card-category-{{ ai_gen_id }} {
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: {{ block.settings.category_color }};
    margin-bottom: 8px;
    font-weight: 500;
  }

  .ai-editorial-card-title-{{ ai_gen_id }} {
    font-size: 20px;
    line-height: 1.3;
    margin: 0 0 12px 0;
    color: {{ block.settings.text_color }};
    font-weight: 500;
  }

  .ai-editorial-card-excerpt-{{ ai_gen_id }} {
    font-size: 14px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-editorial-card-link-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1;
  }

  @media screen and (max-width: 989px) {
    .ai-editorial-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-editorial-hero-{{ ai_gen_id }} {
      grid-column: 1;
    }

    .ai-editorial-sidebar-{{ ai_gen_id }} {
      grid-column: 1;
    }

    .ai-editorial-hero-placeholder-{{ ai_gen_id }} {
      height: 400px;
    }

    .ai-editorial-hero-content-{{ ai_gen_id }} {
      bottom: 24px;
      left: 24px;
      right: 24px;
    }

    .ai-editorial-hero-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.hero_title_size | times: 0.6 }}px;
    }
  }
{% endstyle %}

<div class="ai-editorial-layout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-editorial-container-{{ ai_gen_id }}">
    <div class="ai-editorial-grid-{{ ai_gen_id }}">
      <article class="ai-editorial-hero-{{ ai_gen_id }}">
        {% if block.settings.hero_image %}
          <img
            src="{{ block.settings.hero_image | image_url: width: 1200 }}"
            alt="{{ block.settings.hero_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.hero_image.width }}"
            height="{{ block.settings.hero_image.height }}"
            class="ai-editorial-hero-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-editorial-hero-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
        
        <div class="ai-editorial-hero-overlay-{{ ai_gen_id }}"></div>
        
        <div class="ai-editorial-hero-content-{{ ai_gen_id }}">
          {% if block.settings.hero_category != blank %}
            <div class="ai-editorial-hero-category-{{ ai_gen_id }}">{{ block.settings.hero_category }}</div>
          {% endif %}
          
          {% if block.settings.hero_title != blank %}
            <h2 class="ai-editorial-hero-title-{{ ai_gen_id }}">{{ block.settings.hero_title }}</h2>
          {% endif %}
          
          {% if block.settings.hero_excerpt != blank %}
            <p class="ai-editorial-hero-excerpt-{{ ai_gen_id }}">{{ block.settings.hero_excerpt }}</p>
          {% endif %}
        </div>
        
        {% if block.settings.hero_link != blank %}
          <a href="{{ block.settings.hero_link }}" class="ai-editorial-card-link-{{ ai_gen_id }}" aria-label="{{ block.settings.hero_title | escape }}"></a>
        {% endif %}
      </article>

      <aside class="ai-editorial-sidebar-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          {% liquid
            assign card_image_key = 'card_' | append: i | append: '_image'
            assign card_category_key = 'card_' | append: i | append: '_category'
            assign card_title_key = 'card_' | append: i | append: '_title'
            assign card_excerpt_key = 'card_' | append: i | append: '_excerpt'
            assign card_link_key = 'card_' | append: i | append: '_link'
            
            assign card_image = block.settings[card_image_key]
            assign card_category = block.settings[card_category_key]
            assign card_title = block.settings[card_title_key]
            assign card_excerpt = block.settings[card_excerpt_key]
            assign card_link = block.settings[card_link_key]
          %}
          
          <article class="ai-editorial-card-{{ ai_gen_id }}">
            {% if card_image %}
              <img
                src="{{ card_image | image_url: width: 600 }}"
                alt="{{ card_image.alt | escape }}"
                loading="lazy"
                width="{{ card_image.width }}"
                height="{{ card_image.height }}"
                class="ai-editorial-card-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-editorial-card-placeholder-{{ ai_gen_id }}">
                {{ 'product-apparel-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
            
            <div class="ai-editorial-card-content-{{ ai_gen_id }}">
              {% if card_category != blank %}
                <div class="ai-editorial-card-category-{{ ai_gen_id }}">{{ card_category }}</div>
              {% endif %}
              
              {% if card_title != blank %}
                <h3 class="ai-editorial-card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
              {% endif %}
              
              {% if card_excerpt != blank %}
                <p class="ai-editorial-card-excerpt-{{ ai_gen_id }}">{{ card_excerpt }}</p>
              {% endif %}
            </div>
            
            {% if card_link != blank %}
              <a href="{{ card_link }}" class="ai-editorial-card-link-{{ ai_gen_id }}" aria-label="{{ card_title | escape }}"></a>
            {% endif %}
          </article>
        {% endfor %}
      </aside>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Magazine editorial layout",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_padding",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Section padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Grid gap",
      "default": 20
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Hero article"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "hero_category",
      "label": "Category",
      "default": "Featured"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Title",
      "default": "The Art of Modern Bridal Design"
    },
    {
      "type": "textarea",
      "id": "hero_excerpt",
      "label": "Excerpt",
      "default": "Discover the latest trends in contemporary wedding fashion and timeless elegance."
    },
    {
      "type": "url",
      "id": "hero_link",
      "label": "Link"
    },
    {
      "type": "range",
      "id": "hero_title_size",
      "min": 24,
      "max": 72,
      "step": 4,
      "unit": "px",
      "label": "Title size",
      "default": 48
    },
    {
      "type": "color",
      "id": "hero_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 60
    },
    {
      "type": "header",
      "content": "Card 1"
    },
    {
      "type": "image_picker",
      "id": "card_1_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "card_1_category",
      "label": "Category",
      "default": "Style"
    },
    {
      "type": "text",
      "id": "card_1_title",
      "label": "Title",
      "default": "Minimalist Elegance"
    },
    {
      "type": "textarea",
      "id": "card_1_excerpt",
      "label": "Excerpt",
      "default": "Clean lines and sophisticated silhouettes define this season's aesthetic."
    },
    {
      "type": "url",
      "id": "card_1_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Card 2"
    },
    {
      "type": "image_picker",
      "id": "card_2_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "card_2_category",
      "label": "Category",
      "default": "Trends"
    },
    {
      "type": "text",
      "id": "card_2_title",
      "label": "Title",
      "default": "Vintage Romance"
    },
    {
      "type": "textarea",
      "id": "card_2_excerpt",
      "label": "Excerpt",
      "default": "Timeless details inspired by classic bridal traditions."
    },
    {
      "type": "url",
      "id": "card_2_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Card 3"
    },
    {
      "type": "image_picker",
      "id": "card_3_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "card_3_category",
      "label": "Category",
      "default": "Guide"
    },
    {
      "type": "text",
      "id": "card_3_title",
      "label": "Title",
      "default": "Finding Your Perfect Fit"
    },
    {
      "type": "textarea",
      "id": "card_3_excerpt",
      "label": "Excerpt",
      "default": "Expert advice on choosing the gown that celebrates your unique style."
    },
    {
      "type": "url",
      "id": "card_3_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#2f2e2e"
    },
    {
      "type": "color",
      "id": "category_color",
      "label": "Category",
      "default": "#a52a2a"
    }
  ],
  "presets": [
    {
      "name": "Magazine editorial layout"
    }
  ]
}
{% endschema %}
