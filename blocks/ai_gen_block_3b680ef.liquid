{% doc %}
  @prompt
    A section with 3 seperate blocks. Each block needs a header, a street address field, a phone number field, an email field and a book an appointment button, I need 2 more blocks please
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-appointment-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: {{ block.settings.text_alignment }};
    max-width: 100%;
  }

  .ai-appointment-card__header-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.spacing }}px;
    font-size: {{ block.settings.heading_size }}px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ai-appointment-card__info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.spacing }}px;
    margin-bottom: {{ block.settings.spacing | times: 1.5 }}px;
  }

  .ai-appointment-card__info-item-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  .ai-appointment-card__info-item-{{ ai_gen_id }} svg {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    margin-top: 2px;
  }

  .ai-appointment-card__info-content-{{ ai_gen_id }} {
    flex: 1;
    word-break: break-word;
  }

  .ai-appointment-card__info-content-{{ ai_gen_id }} a {
    color: {{ block.settings.text_color }};
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .ai-appointment-card__info-content-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-appointment-card__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    text-transform: uppercase;
    font-size: {{ block.settings.button_text_size }}px;
    letter-spacing: 0.05em;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .ai-appointment-card__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-appointment-card-{{ ai_gen_id }} {
      padding: {{ block.settings.padding | times: 0.75 }}px;
    }

    .ai-appointment-card__header-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.85 }}px;
    }

    .ai-appointment-card__button-{{ ai_gen_id }} {
      width: 100%;
      text-align: center;
    }
  }
{% endstyle %}

<div class="ai-appointment-card-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h3 class="ai-appointment-card__header-{{ ai_gen_id }}">{{ block.settings.heading }}</h3>
  {% endif %}

  <div class="ai-appointment-card__info-{{ ai_gen_id }}">
    {% if block.settings.street_address != blank %}
      <div class="ai-appointment-card__info-item-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
          <circle cx="12" cy="10" r="3"></circle>
        </svg>
        <div class="ai-appointment-card__info-content-{{ ai_gen_id }}">
          {{ block.settings.street_address }}
        </div>
      </div>
    {% endif %}

    {% if block.settings.phone_number != blank %}
      <div class="ai-appointment-card__info-item-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
        </svg>
        <div class="ai-appointment-card__info-content-{{ ai_gen_id }}">
          <a href="tel:{{ block.settings.phone_number | replace: ' ', '' }}">{{ block.settings.phone_number }}</a>
        </div>
      </div>
    {% endif %}

    {% if block.settings.email != blank %}
      <div class="ai-appointment-card__info-item-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
          <polyline points="22,6 12,13 2,6"></polyline>
        </svg>
        <div class="ai-appointment-card__info-content-{{ ai_gen_id }}">
          <a href="mailto:{{ block.settings.email }}">{{ block.settings.email }}</a>
        </div>
      </div>
    {% endif %}
  </div>

  {% if block.settings.button_link != blank %}
    <a href="{{ block.settings.button_link }}" class="ai-appointment-card__button-{{ ai_gen_id }}">
      {{ block.settings.button_text }}
    </a>
  {% endif %}
</div>

{% schema %}
{
  "name": "Appointment location",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Location details"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Brisbane Boutique"
    },
    {
      "type": "textarea",
      "id": "street_address",
      "label": "Street address",
      "default": "789 Queen Street, Brisbane QLD 4000"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone number",
      "default": "(07) 1234 5678"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "brisbane@example.com"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Book appointment"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "padding",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Padding",
      "default": 30
    },
    {
      "type": "range",
      "id": "spacing",
      "min": 8,
      "max": 32,
      "step": 4,
      "unit": "px",
      "label": "Spacing",
      "default": 16
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "label": "Border width",
      "default": 1
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#fefefe"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#cfc9c8"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#2f2e2e"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#2f2e2e"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover",
      "default": "#a52a2a"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 20
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Background",
      "default": "#2f2e2e"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Border",
      "default": "#2f2e2e"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Hover background",
      "default": "#2f2e2e"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_border_color",
      "label": "Hover border",
      "default": "#2f2e2e"
    },
    {
      "type": "range",
      "id": "button_border_width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "label": "Border width",
      "default": 0
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 0
    },
    {
      "type": "range",
      "id": "button_text_size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 14
    }
  ],
  "presets": [
    {
      "name": "Appointment location"
    }
  ]
}
{% endschema %}