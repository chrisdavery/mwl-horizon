{% assign ai_gen_id = section.id | replace: '_', '' | downcase %}
{% assign block_settings = block.settings %}

{% render 'testimonial-card', ai_gen_id: ai_gen_id, settings: section.settings, customer_name: block_settings.customer_name, testimonial_content: block_settings.testimonial_content, block_settings: block.settings %}
<!--@list/split-->
 
{% schema %}
{
  "name": "Testimonial Card",
  "tag": null,
  "settings": [
    {
      "type": "range",
      "id": "star_rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "label": "Star rating",
      "default": 5
    },
    {
      "type": "richtext",
      "id": "testimonial_content",
      "label": "Testimonial content",
      "default": "<p>This product exceeded my expectations. The quality is outstanding and delivery was fast.</p>"
    },
    {
      "type": "text",
      "id": "customer_name",
      "label": "Customer name",
      "default": "Sarah Johnson"
    }
  ],
  "presets": [
    {
      "name": "Testimonial Card"
    }
  ]
}
{% endschema %}