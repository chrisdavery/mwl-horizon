{% doc %}
  @prompt
    A footer like section with two blocks of text centred to the middle. Each block needs a header and a body of text and option to add a button at the bottom, I need the entire block to fill the page from left to right., add box around both blocks, make boxes smaller in width
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-footer-section-{{ ai_gen_id }} {
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-footer-section__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.gap_between_blocks }}px;
    max-width: {{ block.settings.max_container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-footer-section__block-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: {{ block.settings.block_padding }}px;
    border: {{ block.settings.box_border_width }}px solid {{ block.settings.box_border_color }};
    border-radius: {{ block.settings.box_border_radius }}px;
    background-color: {{ block.settings.box_background_color }};
  }

  .ai-footer-section__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .ai-footer-section__body-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    margin: 0 0 {{ block.settings.text_spacing }}px 0;
    max-width: {{ block.settings.max_text_width }}px;
  }

  .ai-footer-section__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: all 0.3s ease;
  }

  .ai-footer-section__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-footer-section__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.gap_between_blocks | times: 0.5 }}px;
    }

    .ai-footer-section__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-footer-section__body-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-footer-section__button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-footer-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-footer-section__container-{{ ai_gen_id }}">
    <div class="ai-footer-section__block-{{ ai_gen_id }}">
      {% if block.settings.heading_1 != blank %}
        <h3 class="ai-footer-section__heading-{{ ai_gen_id }}">
          {{ block.settings.heading_1 }}
        </h3>
      {% endif %}

      {% if block.settings.body_1 != blank %}
        <div class="ai-footer-section__body-{{ ai_gen_id }}">
          {{ block.settings.body_1 }}
        </div>
      {% endif %}

      {% if block.settings.show_button_1 and block.settings.button_text_1 != blank %}
        <a
          href="{{ block.settings.button_link_1 }}"
          class="ai-footer-section__button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_text_1 }}
        </a>
      {% endif %}
    </div>

    <div class="ai-footer-section__block-{{ ai_gen_id }}">
      {% if block.settings.heading_2 != blank %}
        <h3 class="ai-footer-section__heading-{{ ai_gen_id }}">
          {{ block.settings.heading_2 }}
        </h3>
      {% endif %}

      {% if block.settings.body_2 != blank %}
        <div class="ai-footer-section__body-{{ ai_gen_id }}">
          {{ block.settings.body_2 }}
        </div>
      {% endif %}

      {% if block.settings.show_button_2 and block.settings.button_text_2 != blank %}
        <a
          href="{{ block.settings.button_link_2 }}"
          class="ai-footer-section__button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_text_2 }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

