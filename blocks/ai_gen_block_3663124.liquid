{% doc %}
  @prompt
    A magazine-style editorial layout, double in length and add an accordion, add option to remove images, change more articles accordion to FAQ accordion, add sizing functionality for FAQ's accordion, undo recent change, make FAQ's accordion smaller, remove articles and replace with just text, add multiple boxes for texts for articles, add 3 more articles boxes
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-editorial-layout-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.spacing_top }}px 0 {{ block.settings.spacing_bottom }}px;
  }

  .ai-editorial-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-editorial-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    align-items: start;
  }

  .ai-editorial-featured-{{ ai_gen_id }} {
    grid-column: span 7;
    position: relative;
  }

  .ai-editorial-featured-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-editorial-featured-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 3 / 4;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-editorial-featured-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-featured-content-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: {{ block.settings.content_padding }}px;
    background: linear-gradient(to top, rgba(0,0,0,0.7), rgba(0,0,0,0));
    color: #ffffff;
  }

  .ai-editorial-featured-category-{{ ai_gen_id }} {
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 8px;
    font-weight: 500;
    color: {{ block.settings.category_color }};
  }

  .ai-editorial-featured-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.featured_title_size }}px;
    line-height: 1.2;
    margin: 0 0 12px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .ai-editorial-featured-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.featured_excerpt_size }}px;
    line-height: 1.6;
    margin: 0 0 16px;
    opacity: 0.95;
  }

  .ai-editorial-featured-link-{{ ai_gen_id }} {
    display: inline-block;
    color: #ffffff;
    text-decoration: none;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    border-bottom: 1px solid #ffffff;
    padding-bottom: 2px;
    transition: opacity 0.3s ease;
  }

  .ai-editorial-featured-link-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-editorial-sidebar-{{ ai_gen_id }} {
    grid-column: span 5;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.sidebar_gap }}px;
  }

  .ai-editorial-text-box-{{ ai_gen_id }} {
    padding: {{ block.settings.text_box_padding }}px;
    background-color: {{ block.settings.text_box_bg }};
    border: 1px solid {{ block.settings.border_color }};
  }

  .ai-editorial-text-box-category-{{ ai_gen_id }} {
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 8px;
    font-weight: 500;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
  }

  .ai-editorial-text-box-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_box_title_size }}px;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin: 0 0 10px;
    color: {{ block.settings.text_color }};
  }

  .ai-editorial-text-box-content-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_box_content_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    opacity: 0.85;
  }

  .ai-editorial-text-box-content-{{ ai_gen_id }} p {
    margin: 0 0 12px;
  }

  .ai-editorial-text-box-content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-editorial-faq-section-{{ ai_gen_id }} {
    grid-column: span 12;
    margin-top: {{ block.settings.faq_spacing }}px;
  }

  .ai-editorial-faq-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.faq_section_title_size }}px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin: 0 0 {{ block.settings.faq_title_spacing }}px;
    color: {{ block.settings.text_color }};
    text-align: center;
  }

  .ai-editorial-faq-list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.faq_item_gap }}px;
  }

  .ai-editorial-faq-item-{{ ai_gen_id }} {
    border: 1px solid {{ block.settings.border_color }};
  }

  .ai-editorial-faq-question-{{ ai_gen_id }} {
    background-color: {{ block.settings.faq_question_bg }};
    padding: 12px 20px;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: background-color 0.3s ease;
  }

  .ai-editorial-faq-question-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.faq_question_hover_bg }};
  }

  .ai-editorial-faq-question-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.faq_question_size }}px;
    font-weight: 500;
    letter-spacing: 0.5px;
    margin: 0;
    color: {{ block.settings.text_color }};
    padding-right: 16px;
  }

  .ai-editorial-faq-icon-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    transition: transform 0.3s ease;
    color: {{ block.settings.text_color }};
  }

  .ai-editorial-faq-icon-{{ ai_gen_id }}.active {
    transform: rotate(180deg);
  }

  .ai-editorial-faq-answer-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
    background-color: {{ block.settings.faq_answer_bg }};
  }

  .ai-editorial-faq-answer-{{ ai_gen_id }}.active {
    max-height: 1000px;
  }

  .ai-editorial-faq-answer-inner-{{ ai_gen_id }} {
    padding: 12px 20px;
    font-size: {{ block.settings.faq_answer_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    opacity: 0.85;
  }

  .ai-editorial-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 989px) {
    .ai-editorial-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-editorial-featured-{{ ai_gen_id }},
    .ai-editorial-sidebar-{{ ai_gen_id }},
    .ai-editorial-faq-section-{{ ai_gen_id }} {
      grid-column: span 1;
    }

    .ai-editorial-featured-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.featured_title_size | times: 0.7 }}px;
    }

    .ai-editorial-featured-excerpt-{{ ai_gen_id }} {
      font-size: {{ block.settings.featured_excerpt_size | times: 0.9 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-editorial-text-box-{{ ai_gen_id }} {
      padding: {{ block.settings.text_box_padding | times: 0.8 }}px;
    }

    .ai-editorial-text-box-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_box_title_size | times: 0.9 }}px;
    }

    .ai-editorial-text-box-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_box_content_size | times: 0.9 }}px;
    }

    .ai-editorial-faq-question-{{ ai_gen_id }} {
      padding: 10px 16px;
    }

    .ai-editorial-faq-answer-inner-{{ ai_gen_id }} {
      padding: 10px 16px;
    }

    .ai-editorial-faq-question-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.faq_question_size | times: 0.9 }}px;
    }

    .ai-editorial-faq-answer-inner-{{ ai_gen_id }} {
      font-size: {{ block.settings.faq_answer_size | times: 0.9 }}px;
    }

    .ai-editorial-faq-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.faq_section_title_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-editorial-layout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-editorial-container-{{ ai_gen_id }}">
    <div class="ai-editorial-grid-{{ ai_gen_id }}">
      <div class="ai-editorial-featured-{{ ai_gen_id }}">
        {% if block.settings.featured_image %}
          {% liquid
            assign width = '100%'
            assign media_width_desktop = '100vw'
            assign media_width_mobile = '100vw'
            assign sizes = 'auto, (min-width: 750px) ' | append: media_width_desktop | append: ', ' | append: media_width_mobile
            assign widths = '240, 352, 832, 1200, 1600, 1920, 2560'
            assign image_class = 'ai-editorial-featured-image-{{ ai_gen_id }}'
          %}
          {{
            block.settings.featured_image
            | image_url: width: 2560
            | image_tag: width: width, widths: widths, sizes: sizes, loading: 'lazy', alt: block.settings.featured_image.alt, class: image_class
          }}
        {% else %}
          <div class="ai-editorial-featured-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
            <div class="ai-editorial-empty-state-{{ ai_gen_id }}">
              Add a featured image
            </div>
          </div>
        {% endif %}

        <div class="ai-editorial-featured-content-{{ ai_gen_id }}">
          {% if block.settings.featured_category != blank %}
            <div class="ai-editorial-featured-category-{{ ai_gen_id }}">
              {{ block.settings.featured_category }}
            </div>
          {% endif %}

          {% if block.settings.featured_title != blank %}
            <h2 class="ai-editorial-featured-title-{{ ai_gen_id }}">
              {{ block.settings.featured_title }}
            </h2>
          {% endif %}

          {% if block.settings.featured_excerpt != blank %}
            <div class="ai-editorial-featured-excerpt-{{ ai_gen_id }}">
              {{ block.settings.featured_excerpt }}
            </div>
          {% endif %}

          {% if block.settings.featured_link != blank %}
            <a href="{{ block.settings.featured_link }}" class="ai-editorial-featured-link-{{ ai_gen_id }}">
              {{ block.settings.featured_link_text }}
            </a>
          {% endif %}
        </div>
      </div>

      <div class="ai-editorial-sidebar-{{ ai_gen_id }}">
        {% for i in (1..7) %}
          {% liquid
            assign category_key = 'text_box_' | append: i | append: '_category'
            assign title_key = 'text_box_' | append: i | append: '_title'
            assign content_key = 'text_box_' | append: i | append: '_content'

            assign category = block.settings[category_key]
            assign title = block.settings[title_key]
            assign content = block.settings[content_key]
          %}

          {% if title != blank or content != blank %}
            <div class="ai-editorial-text-box-{{ ai_gen_id }}">
              {% if category != blank %}
                <div class="ai-editorial-text-box-category-{{ ai_gen_id }}">
                  {{ category }}
                </div>
              {% endif %}

              {% if title != blank %}
                <h3 class="ai-editorial-text-box-title-{{ ai_gen_id }}">
                  {{ title }}
                </h3>
              {% endif %}

              {% if content != blank %}
                <div class="ai-editorial-text-box-content-{{ ai_gen_id }}">
                  {{ content }}
                </div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% if block.settings.show_faq %}
        <editorial-faq-{{ ai_gen_id }} class="ai-editorial-faq-section-{{ ai_gen_id }}">
          {% if block.settings.faq_section_title != blank %}
            <h2 class="ai-editorial-faq-title-{{ ai_gen_id }}">
              {{ block.settings.faq_section_title }}
            </h2>
          {% endif %}

          <div class="ai-editorial-faq-list-{{ ai_gen_id }}">
            {% for i in (1..6) %}
              {% liquid
                assign question_key = 'faq_' | append: i | append: '_question'
                assign answer_key = 'faq_' | append: i | append: '_answer'

                assign question = block.settings[question_key]
                assign answer = block.settings[answer_key]
              %}

              {% if question != blank and answer != blank %}
                <div class="ai-editorial-faq-item-{{ ai_gen_id }}">
                  <div class="ai-editorial-faq-question-{{ ai_gen_id }}" role="button" aria-expanded="false" tabindex="0" data-faq-index="{{ i }}">
                    <h3 class="ai-editorial-faq-question-text-{{ ai_gen_id }}">
                      {{ question }}
                    </h3>
                    <svg class="ai-editorial-faq-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                  </div>

                  <div class="ai-editorial-faq-answer-{{ ai_gen_id }}" data-faq-answer="{{ i }}">
                    <div class="ai-editorial-faq-answer-inner-{{ ai_gen_id }}">
                      {{ answer }}
                    </div>
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </editorial-faq-{{ ai_gen_id }}>
      {% endif %}
    </div>
  </div>
</div>

<script>
  (function() {
    class EditorialFaq{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.questions = this.querySelectorAll('.ai-editorial-faq-question-{{ ai_gen_id }}');
        
        this.questions.forEach((question) => {
          question.addEventListener('click', this.toggle.bind(this));
          question.addEventListener('keydown', this.handleKeydown.bind(this));
        });
      }

      toggle(event) {
        const question = event.currentTarget;
        const index = question.getAttribute('data-faq-index');
        const answer = this.querySelector('[data-faq-answer="' + index + '"]');
        const icon = question.querySelector('.ai-editorial-faq-icon-{{ ai_gen_id }}');
        
        const isActive = answer.classList.contains('active');
        
        if (isActive) {
          answer.classList.remove('active');
          icon.classList.remove('active');
          question.setAttribute('aria-expanded', 'false');
        } else {
          answer.classList.add('active');
          icon.classList.add('active');
          question.setAttribute('aria-expanded', 'true');
        }
      }

      handleKeydown(event) {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          this.toggle(event);
        }
      }
    }

    customElements.define('editorial-faq-{{ ai_gen_id }}', EditorialFaq{{ ai_gen_id }});
  })();
</script>

