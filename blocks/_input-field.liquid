{% capture style %}
  {% render 'size-style', settings: block.settings %}
{% endcapture %}

<div
    class="size-style"
    style="{{ style }}"
    {{ block.shopify_attributes }}
>
        {% case block.settings.type %}
            {% when 'textarea' %}
                <custom-input class="custom-input--field">
                    <div class="custom-input-wrapper">
                        <textarea
                        id="CustomForm-{{ block.settings.label | handleize }}"
                        class="custom-form__input"
                        name="properties[{{ block.settings.name }}]"
                        placeholder="{{ block.settings.label }}"
                        rows="5"
                        {% if block.settings.required == true %}
                            required
                        {% endif %}
                        ></textarea>

                        <label
                            for="CustomForm-{{ block.settings.label | handleize }}"
                        >
                            {{ block.settings.label }}{% if block.settings.required == true %}<span aria-hidden="true">*</span>{% endif %}
                        </label>
                    </div>
                    {% if block.settings.error_message != blank %}
                        <div class="error-message hidden">
                            {{ block.settings.error_message }}
                        </div>
                    {% endif %}
                </custom-input>
            {% when 'datepicker' %}
                <div class="group-block-content layout-panel-flex layout-panel-flex--column mobile-column"
                style="--flex-direction: column; --flex-wrap: nowrap; --gap: 12px; --horizontal-alignment: flex-start; --vertical-alignment: center; --vertical-alignment-mobile: center;">
                    <div class="spacing-style text-block custom custom-typography custom-font-size custom-color"
                        style="--padding-block-start: 0px; --padding-block-end:0px; --padding-inline-start:0px; --padding-inline-end:0px; --color: var(--color-foreground); --font-size: 0.875rem; --font-weight: var(--font-subheading--weight); --font-family: var(--font-subheading--family); --text-transform: uppercase; --text-wrap: pretty; --line-height: var(--line-height--body-normal); --letter-spacing: var(--letter-spacing--body-normal); --width: fit-content; --max-width: var(--max-width--body-normal);">
                        {{ block.settings.heading }}
                    </div>
                    <div class="size-style" style="--size-style-width: 100%; --size-style-height: ; --size-style-width-mobile: 100%; --size-style-width-mobile-min: 5rem;">
                        <custom-input class="custom-input--field">
                            <div class="custom-input-wrapper">
                                <date-picker>
                                    <input
                                        type="text"
                                        id="CustomForm-{{ block.settings.label | handleize }}"
                                        name="properties[{{ block.settings.name }}]"
                                        class="custom-form__input"
                                        aria-label="dd/mm/yyyy"
                                        placeholder="dd/mm/yyyy"
                                        readonly
                                        autocomplete="off"
                                        data-start-date="{{ block.settings.start_date }}"
                                    >
                                    <label
                                        for="CustomForm-{{ block.settings.label | handleize }}"
                                    >
                                        {{ block.settings.label }}{% if block.settings.required == true %}<span aria-hidden="true">*</span>{% endif %}
                                    </label>

                                    <span class="datepicker-icon">
                                        {{- 'icon-date.svg' | inline_asset_content -}}
                                    </span>
                                    <div class="ai-datepicker-calendar">
                                        <div class="ai-datepicker-header">
                                            <button type="button" class="ai-datepicker-nav" data-action="prev-month" aria-label="Previous month">
                                                {{- 'icon-caret.svg' | inline_asset_content -}}
                                            </button>
                                            <div class="ai-datepicker-month-year h5"></div>
                                    
                                            <button type="button" class="ai-datepicker-nav" data-action="next-month" aria-label="Next month">
                                                {{- 'icon-caret.svg' | inline_asset_content -}}
                                            </button>
                                        </div>
                                    
                                        <div class="ai-datepicker-grid">
                                            <div class="ai-datepicker-day-header">S</div>
                                            <div class="ai-datepicker-day-header">M</div>
                                            <div class="ai-datepicker-day-header">T</div>
                                            <div class="ai-datepicker-day-header">W</div>
                                            <div class="ai-datepicker-day-header">T</div>
                                            <div class="ai-datepicker-day-header">F</div>
                                            <div class="ai-datepicker-day-header">S</div>
                                        </div>
                                        <div class="ai-datepicker-year-selector hidden"></div>
                                    </div>
                                </date-picker>
                            </div>
                            {% if block.settings.error_message != blank %}
                                <div class="error-message hidden">
                                    {{ block.settings.error_message }}
                                </div>
                            {% endif %}
                        </custom-input>
                    </div>
                </div>

            {% else %}
                <custom-input class="custom-input--field">
                    <div class="custom-input-wrapper">
                        <input
                            type="{{ block.settings.type }}"
                            id="CustomForm-{{ block.settings.label | handleize }}"
                            class="custom-form__input"
                            autocomplete="name"
                            form="{{ product_form_id }}"
                            name="properties[{{ block.settings.name }}]"
                            placeholder="{{ block.settings.label }}"
                            {% if block.settings.required == true %}
                                required
                            {% endif %}
                        >

                        <label
                            for="CustomForm-{{ block.settings.label | handleize }}"
                        >
                            {{ block.settings.label }}{% if block.settings.required == true %}<span aria-hidden="true">*</span>{% endif %}
                        </label>
                    </div>
                    {% if block.settings.error_message != blank %}
                        <div class="error-message hidden">
                            {{ block.settings.error_message }}
                        </div>
                    {% endif %}
                </custom-input> 
        {% endcase %}

</div>

{% stylesheet %}
    .custom-input--field {
        width: 100%;
        display: block;
    }
    .custom-input-wrapper {
        position: relative;
    }

    .error-message {
        margin-top: var(--margin-2xs);
        line-height: 1em;
    }

    .has-error .error-message {
        display: block !important;
        color: var(--color-primary-hover);
    }

    .custom-input--field.has-error label {
        color: var(--color-primary-hover);
    }

    .custom-input--field.has-error {
        --color-input-border: var(--color-primary-hover);
    }

    .custom-form__input {
        width: 100%;
        overflow: hidden;
        text-overflow: ellipsis;
        color: var(--color-foreground);
        background-color: var(--color-input-background);
        padding: var(--padding-lg) var(--padding-xl) var(--padding-2xs);
        border-radius: var(--style-border-radius-inputs);
        border: var(--style-border-width-inputs) solid var(--color-input-border);
        -webkit-font-smoothing: antialiased;
    }
    
    .custom-form__input::placeholder {
        visibility: hidden;
    }

    .custom-input--field label {
        position: absolute;
        top: 1rem;
        left: var(--margin-xl);
        pointer-events: none;
        transition-duration: var(--hover-transition-duration);
        transition-property: all;
        transition-timing-function: cubic-bezier(.4,0,.2,1);
        width: calc(100% - var(--margin-xl));
        line-height: 1em;
    }

    .custom-form__input:focus~label,.custom-form__input:not(:placeholder-shown) ~ label {
        font-size: var(--font-size--xs);
        letter-spacing: .2px;
        top: 6px;
        width: calc(100% - var(--margin-xl));
    }
    
    .ai-datepicker-month-year {
        cursor: pointer;
        position: relative;
    }

    .ai-datepicker-month-year:after {
        content: url("data:image/svg+xml;utf8,<svg width='14' height='14' viewBox='0 0 14 14' fill='none' xmlns='http://www.w3.org/2000/svg'><path d='M11 5.5L7 9.5L3 5.5' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/></svg>");
        position: absolute;
        right: -1rem;
        top: .1rem;
    }

    .ai-datepicker-container {
        position: relative;
        width: 100%;
    }

    .ai-datepicker-calendar {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: var(--color-background);
        border: 1px solid var(--color-border);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
        z-index: 1000;
        opacity: 0;
        visibility: hidden;
        transform: translateY(-10px);
        transition: opacity 0.3s ease, visibility 0.3s ease, transform 0.3s ease;
        margin-top: var(--margin-xs);
    }

    .ai-datepicker-calendar.active {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
    }

    .ai-datepicker-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px;
    }

    .ai-datepicker-nav {
        background: none;
        border: none;
        cursor: pointer;
        padding: var(--padding-2xs);
        transition: background-color 0.2s ease;
        -webkit-tap-highlight-color: transparent;
    }

    .ai-datepicker-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: var(--gap-2xs);
        padding: 16px;
    }

    .ai-datepicker-day-header {
        text-align: center;
        font-family: var(--font-subheading--family);
        font-style: var(--font-subheading--style);
        font-weight: var(--font-subheading--weight);
        font-size: var(--font-size--sm);
    }

    .ai-datepicker-day {
        padding: var(--padding-2xs) var(--padding-xs);
        text-align: center;
        cursor: pointer;
        transition: background-color 0.2s ease;
        font-family: var(--font-subheading--family);
        font-style: var(--font-subheading--style);
        font-weight: var(--font-subheading--weight);
        font-size: var(--font-size--sm);
    }

    .ai-datepicker-day.selected {
        background-color: var(--color-primary-button-background);
        color: var(--color-primary-button-text);
    }

    .ai-datepicker-day.disabled {
        cursor: not-allowed;
        opacity: 0.3;
    }

    .ai-datepicker-day.other-month {
        opacity: 0.3;
    }

    .ai-datepicker-year-selector {
        max-height: 300px; /* or any height you want */
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: var(--gap-xs); /* spacing between years */
        padding: var(--padding-sm);
    }

    .ai-datepicker-year-selector span {
        cursor: pointer;
        padding: var(--padding-2xs);
        text-align: center;
        font-family: var(--font-subheading--family);
        font-style: var(--font-subheading--style);
        font-weight: var(--font-subheading--weight);
        font-size: var(--font-size--sm);
    }

    .ai-datepicker-year-selector span.selected {
        font-size: var(--font-h3--size);
    }

    .ai-datepicker-year.disabled {
        opacity: .3;
        pointer-events: none;
        cursor: not-allowed;
    }

    .ai-datepicker-nav[data-action="prev-month"] svg {
        transform: rotate(90deg);
    }

    .ai-datepicker-nav[data-action="next-month"] svg {
        transform: rotate(-90deg);
    }

    .datepicker-icon {
        position: absolute;
        right: var(--padding-xl);
        top: 50%;
        transform: translateY(-50%);
    }
    .datepicker-icon svg {
        display: block;
    }

    @media screen and (max-width: 749px) {
        .ai-datepicker-calendar {
            left: 0;
            right: 0;
        }
    }
{% endstylesheet %}

{% schema %}
    {
        "name": "Input Field",
        "tag": null,
        "settings": [
            {
                "type": "text",
                "id": "label",
                "label": "Label"
            },
            {
                "type": "text",
                "id": "name",
                "label": "Name"
            },
            {
            "type": "select",
            "id": "type",
            "label": "Field type",
            "options": [
                {
                    "value": "text",
                    "label": "Text"
                },
                {
                    "value": "email",
                    "label": "Email"
                },
                {
                    "value": "tel",
                    "label": "Telephone"
                },
                {
                    "value": "number",
                    "label": "Number"
                },
                {
                    "value": "textarea",
                    "label": "Textarea"
                },
                {
                    "value": "datepicker",
                    "label": "Date picker"
                }
            ],
            "default": "text"
            },
            {
                "type": "inline_richtext",
                "id": "heading",
                "label": "Heading",
                "visible_if": "{{ block.settings.type == 'datepicker' }}"
            },
            {
                "type": "text",
                "id": "start_date",
                "label": "Start date",
                "info": "Format: YYYY-MM-DD. Leave empty to use today's date.",
                "visible_if": "{{ block.settings.type == 'datepicker' }}"
            },
            {
                "type": "checkbox",
                "id": "required",
                "label": "Required",
                "default": false
            },
            {
                "type": "text",
                "id": "error_message",
                "label": "Error message"
            },
            {
                "type": "select",
                "id": "width",
                "label": "t:settings.width_desktop",
                "options": [
                    {
                    "value": "fit-content",
                    "label": "t:options.fit_content"
                    },
                    {
                    "value": "fill",
                    "label": "t:options.fill"
                    },
                    {
                    "value": "custom",
                    "label": "t:options.custom"
                    }
                ],
                "default": "fill"
                },
                {
                "type": "range",
                "id": "custom_width",
                "label": "t:settings.custom_width",
                "min": 0,
                "max": 100,
                "step": 1,
                "unit": "%",
                "default": 100,
                "visible_if": "{{ block.settings.width == 'custom' }}"
                },
                {
                "type": "select",
                "id": "width_mobile",
                "label": "t:settings.width_mobile",
                "options": [
                    {
                    "value": "fit-content",
                    "label": "t:options.fit_content"
                    },
                    {
                    "value": "fill",
                    "label": "t:options.fill"
                    },
                    {
                    "value": "custom",
                    "label": "t:options.custom"
                    }
                ],
                "default": "fill"
                },
                {
                "type": "range",
                "id": "custom_width_mobile",
                "label": "t:settings.custom_width",
                "min": 0,
                "max": 100,
                "step": 1,
                "unit": "%",
                "default": 100,
                "visible_if": "{{ block.settings.width_mobile == 'custom' }}"
                }
        ],
        "presets": [
            {
            "name": "Input Field",
            "category": "t:categories.forms"
            }
        ]
    }
{% endschema %}