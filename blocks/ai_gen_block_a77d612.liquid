{% doc %}
  @prompt
    A carousel gallery of 8 images with clickable text underneath, remove circle borders from carousel arrows
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-carousel-gallery-{{ ai_gen_id }} {
    width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-carousel-gallery-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
  }

  .ai-carousel-gallery-wrapper-{{ ai_gen_id }} {
    overflow: hidden;
    position: relative;
  }

  .ai-carousel-gallery-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    transition: transform 0.5s ease;
  }

  .ai-carousel-gallery-slide-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.slides_per_view | minus: 1 }} * {{ block.settings.gap }}px)) / {{ block.settings.slides_per_view }});
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-carousel-gallery-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: #f4f4f4;
  }

  .ai-carousel-gallery-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-carousel-gallery-image-wrapper-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-carousel-gallery-text-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    cursor: pointer;
    transition: color 0.3s ease;
  }

  .ai-carousel-gallery-text-{{ ai_gen_id }}:hover {
    color: {{ block.settings.text_hover_color }};
  }

  .ai-carousel-gallery-controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: 30px;
  }

  .ai-carousel-gallery-button-{{ ai_gen_id }} {
    width: 44px;
    height: 44px;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s ease;
  }

  .ai-carousel-gallery-button-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-carousel-gallery-button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-carousel-gallery-button-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
    stroke: {{ block.settings.button_icon_color }};
  }

  .ai-carousel-gallery-dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-carousel-gallery-dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: background-color 0.3s ease;
    padding: 0;
  }

  .ai-carousel-gallery-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-carousel-gallery-slide-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.slides_per_view_mobile | minus: 1 }} * {{ block.settings.gap }}px)) / {{ block.settings.slides_per_view_mobile }});
    }
  }
{% endstyle %}

<carousel-gallery-{{ ai_gen_id }} class="ai-carousel-gallery-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-carousel-gallery-container-{{ ai_gen_id }}">
    <div class="ai-carousel-gallery-wrapper-{{ ai_gen_id }}">
      <div class="ai-carousel-gallery-track-{{ ai_gen_id }}">
        {% for i in (1..8) %}
          {% liquid
            assign image_key = 'image_' | append: i
            assign text_key = 'text_' | append: i
            assign link_key = 'link_' | append: i
            
            assign image = block.settings[image_key]
            assign text = block.settings[text_key]
            assign link = block.settings[link_key]
          %}
          
          <div class="ai-carousel-gallery-slide-{{ ai_gen_id }}">
            <div class="ai-carousel-gallery-image-wrapper-{{ ai_gen_id }}">
              {% if image %}
                <img
                  src="{{ image | image_url: width: 600 }}"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                  width="600"
                  height="600"
                  class="ai-carousel-gallery-image-{{ ai_gen_id }}"
                >
              {% else %}
                {{ 'image' | placeholder_svg_tag }}
              {% endif %}
            </div>
            {% if text != blank %}
              {% if link != blank %}
                <a href="{{ link }}" class="ai-carousel-gallery-text-{{ ai_gen_id }}">{{ text }}</a>
              {% else %}
                <div class="ai-carousel-gallery-text-{{ ai_gen_id }}">{{ text }}</div>
              {% endif %}
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="ai-carousel-gallery-controls-{{ ai_gen_id }}">
      <button
        class="ai-carousel-gallery-button-{{ ai_gen_id }} ai-carousel-gallery-prev-{{ ai_gen_id }}"
        aria-label="Previous slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <div class="ai-carousel-gallery-dots-{{ ai_gen_id }}"></div>

      <button
        class="ai-carousel-gallery-button-{{ ai_gen_id }} ai-carousel-gallery-next-{{ ai_gen_id }}"
        aria-label="Next slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  </div>
</carousel-gallery-{{ ai_gen_id }}>

<script>
  (function() {
    class CarouselGallery{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.slidesPerView = {{ block.settings.slides_per_view }};
        this.slidesPerViewMobile = {{ block.settings.slides_per_view_mobile }};
        this.totalSlides = 8;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-carousel-gallery-track-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-carousel-gallery-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-carousel-gallery-next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-carousel-gallery-dots-{{ ai_gen_id }}');

        this.updateSlidesPerView();
        this.createDots();
        this.updateCarousel();
        this.setupEventListeners();
      }

      updateSlidesPerView() {
        if (window.innerWidth <= 749) {
          this.slidesPerView = this.slidesPerViewMobile;
        } else {
          this.slidesPerView = {{ block.settings.slides_per_view }};
        }
        this.maxIndex = Math.max(0, this.totalSlides - this.slidesPerView);
      }

      createDots() {
        this.dotsContainer.innerHTML = '';
        const numDots = this.maxIndex + 1;
        
        for (let i = 0; i <= this.maxIndex; i++) {
          const dot = document.createElement('button');
          dot.classList.add('ai-carousel-gallery-dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
          dot.addEventListener('click', () => this.goToSlide(i));
          this.dotsContainer.appendChild(dot);
        }
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.prev());
        this.nextButton.addEventListener('click', () => this.next());

        window.addEventListener('resize', () => {
          this.updateSlidesPerView();
          this.createDots();
          this.currentIndex = Math.min(this.currentIndex, this.maxIndex);
          this.updateCarousel();
        });
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updateCarousel();
        }
      }

      next() {
        if (this.currentIndex < this.maxIndex) {
          this.currentIndex++;
          this.updateCarousel();
        }
      }

      goToSlide(index) {
        this.currentIndex = index;
        this.updateCarousel();
      }

      updateCarousel() {
        const slideWidth = this.track.querySelector('.ai-carousel-gallery-slide-{{ ai_gen_id }}').offsetWidth;
        const gap = {{ block.settings.gap }};
        const offset = this.currentIndex * (slideWidth + gap);
        
        this.track.style.transform = 'translateX(-' + offset + 'px)';

        this.prevButton.disabled = this.currentIndex === 0;
        this.nextButton.disabled = this.currentIndex === this.maxIndex;

        const dots = this.dotsContainer.querySelectorAll('.ai-carousel-gallery-dot-{{ ai_gen_id }}');
        dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    }

    customElements.define('carousel-gallery-{{ ai_gen_id }}', CarouselGallery{{ ai_gen_id }});
  })();
</script>

