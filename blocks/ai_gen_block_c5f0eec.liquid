{% doc %}
  @prompt
    A footer like section with two blocks of text centred to the left. Each block needs a header and a body of text, I need the entire block to fill the page from left to right
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-footer-text-blocks-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
    width: 100%;
  }

  .ai-footer-text-blocks__container-{{ ai_gen_id }} {
    max-width: 100%;
    width: 100%;
    margin: 0;
    padding: 0 {{ block.settings.horizontal_padding }}px;
    display: flex;
    gap: {{ block.settings.gap_between_blocks }}px;
    align-items: flex-start;
  }

  .ai-footer-text-blocks__block-{{ ai_gen_id }} {
    flex: 1;
    text-align: left;
  }

  .ai-footer-text-blocks__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    text-transform: {{ block.settings.heading_text_transform }};
  }

  .ai-footer-text-blocks__body-{{ ai_gen_id }} {
    color: {{ block.settings.body_color }};
    font-size: {{ block.settings.body_size }}px;
    line-height: {{ block.settings.body_line_height }};
    margin: 0;
  }

  .ai-footer-text-blocks__body-{{ ai_gen_id }} p {
    margin: 0 0 {{ block.settings.paragraph_spacing }}px 0;
  }

  .ai-footer-text-blocks__body-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-footer-text-blocks__container-{{ ai_gen_id }} {
      flex-direction: {{ block.settings.mobile_layout }};
      gap: {{ block.settings.mobile_gap }}px;
      padding: 0 {{ block.settings.mobile_horizontal_padding }}px;
    }

    .ai-footer-text-blocks__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.85 }}px;
    }

    .ai-footer-text-blocks__body-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-footer-text-blocks-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-footer-text-blocks__container-{{ ai_gen_id }}">
    <div class="ai-footer-text-blocks__block-{{ ai_gen_id }}">
      {% if block.settings.heading_1 != blank %}
        <h3 class="ai-footer-text-blocks__heading-{{ ai_gen_id }}">
          {{ block.settings.heading_1 }}
        </h3>
      {% endif %}
      {% if block.settings.body_1 != blank %}
        <div class="ai-footer-text-blocks__body-{{ ai_gen_id }}">
          {{ block.settings.body_1 }}
        </div>
      {% endif %}
    </div>

    <div class="ai-footer-text-blocks__block-{{ ai_gen_id }}">
      {% if block.settings.heading_2 != blank %}
        <h3 class="ai-footer-text-blocks__heading-{{ ai_gen_id }}">
          {{ block.settings.heading_2 }}
        </h3>
      {% endif %}
      {% if block.settings.body_2 != blank %}
        <div class="ai-footer-text-blocks__body-{{ ai_gen_id }}">
          {{ block.settings.body_2 }}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Footer text blocks",
  "settings": [
    {
      "type": "header",
      "content": "Block 1"
    },
    {
      "type": "inline_richtext",
      "id": "heading_1",
      "label": "Heading",
      "default": "About Us"
    },
    {
      "type": "richtext",
      "id": "body_1",
      "label": "Body text",
      "default": "<p>We are dedicated to providing exceptional service and quality products to our customers.</p>"
    },
    {
      "type": "header",
      "content": "Block 2"
    },
    {
      "type": "inline_richtext",
      "id": "heading_2",
      "label": "Heading",
      "default": "Contact"
    },
    {
      "type": "richtext",
      "id": "body_2",
      "label": "Body text",
      "default": "<p>Get in touch with us for any inquiries or support. We're here to help.</p>"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "horizontal_padding",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Vertical padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "gap_between_blocks",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Gap between blocks",
      "default": 60
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile layout",
      "options": [
        {
          "value": "column",
          "label": "Stack vertically"
        },
        {
          "value": "row",
          "label": "Side by side"
        }
      ],
      "default": "column"
    },
    {
      "type": "range",
      "id": "mobile_gap",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Mobile gap",
      "default": 30
    },
    {
      "type": "range",
      "id": "mobile_horizontal_padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Mobile horizontal padding",
      "default": 20
    },
    {
      "type": "header",
      "content": "Heading style"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color",
      "default": "#2f2e2e"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Size",
      "default": 20
    },
    {
      "type": "select",
      "id": "heading_text_transform",
      "label": "Text transform",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        }
      ],
      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "min": 5,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Spacing below",
      "default": 12
    },
    {
      "type": "header",
      "content": "Body text style"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Color",
      "default": "#2f2e2e"
    },
    {
      "type": "range",
      "id": "body_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Size",
      "default": 16
    },
    {
      "type": "range",
      "id": "body_line_height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "label": "Line height",
      "default": 1.6
    },
    {
      "type": "range",
      "id": "paragraph_spacing",
      "min": 5,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Paragraph spacing",
      "default": 12
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f8f6ef"
    }
  ],
  "presets": [
    {
      "name": "Footer text blocks"
    }
  ]
}
{% endschema %}
