{% doc %}
  @prompt
    I need a footer like section that has two blocks of text, both blocks need to be centred to the left. Each block needs a header and a body of text., please centre text within both blocks
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-footer-text-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-footer-text-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-footer-text-blocks-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.column_gap }}px;
  }

  .ai-footer-text-block-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-footer-text-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    text-transform: {{ block.settings.heading_transform }};
  }

  .ai-footer-text-body-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-footer-text-blocks-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_gap }}px;
    }
  }
{% endstyle %}

<div class="ai-footer-text-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-footer-text-container-{{ ai_gen_id }}">
    <div class="ai-footer-text-blocks-{{ ai_gen_id }}">
      <div class="ai-footer-text-block-{{ ai_gen_id }}">
        {% if block.settings.heading_1 != blank %}
          <h3 class="ai-footer-text-heading-{{ ai_gen_id }}">{{ block.settings.heading_1 }}</h3>
        {% endif %}
        {% if block.settings.body_1 != blank %}
          <div class="ai-footer-text-body-{{ ai_gen_id }}">{{ block.settings.body_1 }}</div>
        {% endif %}
      </div>

      <div class="ai-footer-text-block-{{ ai_gen_id }}">
        {% if block.settings.heading_2 != blank %}
          <h3 class="ai-footer-text-heading-{{ ai_gen_id }}">{{ block.settings.heading_2 }}</h3>
        {% endif %}
        {% if block.settings.body_2 != blank %}
          <div class="ai-footer-text-body-{{ ai_gen_id }}">{{ block.settings.body_2 }}</div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Footer text blocks",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Block 1"
    },
    {
      "type": "inline_richtext",
      "id": "heading_1",
      "label": "Heading",
      "default": "First heading"
    },
    {
      "type": "richtext",
      "id": "body_1",
      "label": "Body text",
      "default": "<p>Add your text content here. This is the first block of text that will be aligned to the left.</p>"
    },
    {
      "type": "header",
      "content": "Block 2"
    },
    {
      "type": "inline_richtext",
      "id": "heading_2",
      "label": "Heading",
      "default": "Second heading"
    },
    {
      "type": "richtext",
      "id": "body_2",
      "label": "Body text",
      "default": "<p>Add your text content here. This is the second block of text that will be aligned to the left.</p>"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 600,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "label": "Maximum width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "column_gap",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Gap between columns",
      "default": 60
    },
    {
      "type": "range",
      "id": "mobile_gap",
      "min": 20,
      "max": 80,
      "step": 10,
      "unit": "px",
      "label": "Gap on mobile",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f8f6ef"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#2f2e2e"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body text",
      "default": "#2f2e2e"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 20
    },
    {
      "type": "select",
      "id": "heading_transform",
      "label": "Heading text case",
      "options": [
        {
          "value": "none",
          "label": "Default"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        }
      ],
      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Heading bottom spacing",
      "default": 16
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Body text size",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Footer text blocks"
    }
  ]
}
{% endschema %}
