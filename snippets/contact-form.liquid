{%- doc -%}
  Renders a contact form with name, email, phone, and comment fields.

  @param {object} settings - Block settings, required for the 'spacing-style' and 'size-style' snippets.
  @param {string} submit_button - HTML for the submit button, rendered via a `content_for` block.

  @example
  {% render 'contact-form', settings: block.settings, submit_button: content_for_submit_button %}
{%- enddoc -%}

<div
  class="
    contact-form
    spacing-style size-style
    {% if settings.inherit_color_scheme == false %}color-{{ settings.color_scheme }}{% endif %}
  "
  style="
    {% render 'spacing-style', settings: settings %}
    {% render 'size-style', settings: settings %}
  "
  {{ block.shopify_attributes }}
>
  {% assign form_id = block.id | default: section.id | prepend: 'ContactForm-' %}

  {%- form 'contact', id: form_id, class: 'contact-form__form' -%}
    {%- if form.errors -%}
      <div
        class="contact-form__error"
        tabindex="-1"
        autofocus
      >
        {{- 'icon-error.svg' | inline_asset_content -}}

        {{- form.errors.translated_fields.email | capitalize }}
        {{ form.errors.messages.email -}}
      </div>
    {%- endif -%}

    {%- if form.posted_successfully? -%}
      <div
        class="contact-form__success"
        tabindex="-1"
        autofocus
      >
        {{- 'icon-checkmark.svg' | inline_asset_content -}}
        {{- 'blocks.contact_form.post_success' | t -}}
      </div>
    {%- endif -%}


    {% liquid
      assign countries = settings.countries | newline_to_br | split: '<br />'
    %}

    {% if countries.size > 0 %}
      <div class="select-option hidden">
          <div class="option__select-wrapper">
              <label for="Option-country">{{- 'blocks.contact_form.country' | t -}}</label>
              <select id="Option-country" name="contact[country]"
                  class="option__select">
                  {% for country in countries %}
                      <option value="{{ country | strip }}" selected="selected">
                          {{ country }}
                      </option>
                  {% endfor %}
              </select>
              <svg
              aria-hidden="true"
              focusable="false"
              class="icon icon-caret"
              viewBox="0 0 10 6"
              >
              {%- render 'icon', icon: 'caret' -%}
              </svg>
          </div>
      </div>
    {% endif %}

    <div class="contact-form__form-row">
      <label
        class="visually-hidden"
        for="ContactForm-firstname"
      >
        {{- 'blocks.contact_form.first_name' | t -}}<span aria-hidden="true">*</span>
      </label>
      <input
        type="text"
        id="ContactForm-firstname"
        class="contact-form__input"
        name="contact[firstname]"
        required
        value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
        placeholder="{{ 'blocks.contact_form.first_name' | t }}*"
      >
      <label
        class="visually-hidden"
        for="ContactForm-lastname"
      >
        {{- 'blocks.contact_form.last_name' | t -}}<span aria-hidden="true">*</span>
      </label>
      <input
        type="text"
        id="ContactForm-lastname"
        class="contact-form__input"
        name="contact[last_name]"
        required
        value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
        placeholder="{{ 'blocks.contact_form.last_name' | t }}*"
      >
    </div>

      <label
        class="visually-hidden"
        for="ContactForm-email"
      >
        {{- 'blocks.contact_form.email' | t -}}
        <span aria-hidden="true">*</span></label
      >
      <input
        type="email"
        id="ContactForm-email"
        class="contact-form__input"
        autocomplete="email"
        name="contact[email]"
        spellcheck="false"
        autocapitalize="off"
        value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
        aria-required="true"
        {% if form.errors contains 'email' %}
          aria-invalid="true"
          aria-describedby="ContactForm-email-error"
        {% endif %}
        placeholder="{{ 'blocks.contact_form.email' | t }}*"
      >
        
    <label
      class="visually-hidden"
      for="ContactForm-phone"
    >
      {{- 'blocks.contact_form.phone' | t -}}
    </label>
    <input
      type="tel"
      id="ContactForm-phone"
      class="contact-form__input"
      autocomplete="tel"
      name="contact[phone]"
      pattern="[0-9\-]*"
      value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
      placeholder="{{ 'blocks.contact_form.phone' | t }}"
    >

    <div class="group-block-content parent-group-datepicker layout-panel-flex layout-panel-flex--column mobile-column" style="--flex-direction: column; --flex-wrap: nowrap; --gap: 12px; --horizontal-alignment: flex-start; --vertical-alignment: center; --vertical-alignment-mobile: center;">
        <div class="spacing-style text-block custom custom-typography custom-font-size custom-color" style="--padding-block-start: 0px; --padding-block-end:0px; --padding-inline-start:0px; --padding-inline-end:0px; --color: var(--color-foreground); --font-size: var(--font-size--xs); --font-weight: var(--font-subheading--weight); --font-family: var(--font-subheading--family); --text-transform: uppercase; --text-wrap: pretty; --line-height: var(--line-height--body-normal); --letter-spacing: var(--letter-spacing--body-normal); --width: fit-content; --max-width: var(--max-width--body-normal);">{{ 'blocks.contact_form.your_wedding_date' | t }}</div>
        <div class="size-style" style="--size-style-width: 100%; --size-style-height: ; --size-style-width-mobile: 100%; --size-style-width-mobile-min: 5rem;">
            <custom-input class="custom-input--field">
            <div class="custom-input-wrapper">
                <date-picker>
                  <input type="text" id="CustomForm-dd-mm-yyyy" name="contact[{{ 'blocks.contact_form.your_wedding_date' | t }}]" class="custom-form__input" aria-label="dd/mm/yyyy" placeholder="dd/mm/yyyy" readonly="" autocomplete="off" data-lead-date="">
                  <label for="CustomForm-dd-mm-yyyy">dd/mm/yyyy</label>
                  <span class="datepicker-icon">
                      {{- 'icon-date.svg' | inline_asset_content -}}
                  </span>
                  <div class="ai-datepicker-calendar">
                      <div class="ai-datepicker-header">
                          <button type="button" class="ai-datepicker-nav" data-action="prev-month" aria-label="Previous month">
                              {{- 'icon-caret.svg' | inline_asset_content -}}
                          </button>
                          <div class="ai-datepicker-month-year h5"></div>

                          <button type="button" class="ai-datepicker-nav" data-action="next-month" aria-label="Next month">
                              {{- 'icon-caret.svg' | inline_asset_content -}}
                          </button>
                      </div>
                  
                      <div class="ai-datepicker-grid">
                          <div class="ai-datepicker-day-header">S</div>
                          <div class="ai-datepicker-day-header">M</div>
                          <div class="ai-datepicker-day-header">T</div>
                          <div class="ai-datepicker-day-header">W</div>
                          <div class="ai-datepicker-day-header">T</div>
                          <div class="ai-datepicker-day-header">F</div>
                          <div class="ai-datepicker-day-header">S</div>
                      </div>
                      <div class="ai-datepicker-year-selector hidden"></div>
                  </div>
                </date-picker>
            </div>
            </custom-input>
        </div>
    </div>
    <label
      class="visually-hidden"
      for="ContactForm-body"
    >
      {{- 'blocks.contact_form.comment' | t -}}
    </label>
    <textarea
      rows="10"
      id="ContactForm-body"
      class="contact-form__input contact-form__input--textarea"
      name="contact[body]"
      placeholder="{{ 'blocks.contact_form.comment' | t }}"
    >
      {{- form.body -}}
    </textarea>

    {{ submit_button }}
  {%- endform -%}
</div>

{% stylesheet %}
  .contact-form__form {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
  }

  .contact-form__form-row {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);

    @media screen and (min-width: 750px) {
      flex-direction: row;
      align-items: center;
    }
  }

  .contact-form__input {
    width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--color-foreground);
    background-color: var(--color-input-background);
    padding: var(--padding-sm) var(--padding-xl);
    border-radius: var(--style-border-radius-inputs);
    border: var(--style-border-width-inputs) solid var(--color-input-border);
    -webkit-font-smoothing: antialiased;
  }

  .contact-form__input--textarea {
    resize: vertical;
    min-height: var(--input-textarea-min-height);
  }

  .contact-form__error,
  .contact-form__success {
    display: flex;
    align-items: center;
    gap: var(--gap-xs);
  }
{% endstylesheet %}

{% if countries.size > 0 %}
  <script
  src="{{ 'country-dropdown.js' | asset_url }}"
  defer
  type="module"
></script>
{% endif %}

<script>
document.addEventListener('DOMContentLoaded', function () {
  // Target your actual form by ID
  const form = document.getElementById('{{ form_id }}'); 

  if (!form) return;

  form.addEventListener('submit', function () {
    // Collect values directly from your form fields
    const data = {
      first_name: document.getElementById('ContactForm-firstname')?.value || '',
      last_name: document.getElementById('ContactForm-lastname')?.value || '',
      email: document.getElementById('ContactForm-email')?.value || '',
      phone: document.getElementById('ContactForm-phone')?.value || '',
      country: document.getElementById('Option-country')?.value || '',
      date: document.getElementById('CustomForm-dd-mm-yyyy')?.value || '',
      enquiry: document.getElementById('ContactForm-body')?.value || ''
    };

    // Send to Zapier
    fetch('https://hooks.zapier.com/hooks/catch/2280371/uym2c7u/', {
      method: 'POST',
      mode: 'no-cors',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify(data)
    }).then(() => {
      console.log('Zapier webhook triggered');
    }).catch(error => {
      console.error('Zapier webhook error:', error);
    });
  });
});
</script>