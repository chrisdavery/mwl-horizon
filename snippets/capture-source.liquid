<script>
try {
  var urlParams = new URLSearchParams(window.location.search);
  var src = urlParams.get('source') || urlParams.get('platform'); // existing params

  // 1️⃣ Detect platform from Linktree UTM params if none found
  if (!src) {
    var utmSource = urlParams.get('utm_source') || '';
    if (utmSource.includes('ig')) src = 'instagram';
    else if (utmSource.includes('tiktok')) src = 'tiktok';
    else if (utmSource.includes('fb')) src = 'facebook';
    else if (utmSource.includes('pinterest')) src = 'pinterest';
  }

  // 2️⃣ If still not detected, use referrer
  var ref = document.referrer.toLowerCase();
  if (!src) {
    if (ref.includes('instagram.com')) src = 'instagram';
    else if (ref.includes('tiktok.com')) src = 'tiktok';
    else if (ref.includes('facebook.com')) src = 'facebook';
    else if (ref.includes('pinterest.com')) src = 'pinterest';
    else src = 'direct';
  }

  // 3️⃣ Fallback to direct
  if (!src) src = 'direct';

  // 4️⃣ Save cookie for 24 hours
  var d = new Date();
  d.setTime(d.getTime() + 24 * 60 * 60 * 1000);
  document.cookie =
    "booking_source=" + encodeURIComponent(src) +
    "; path=/; expires=" + d.toUTCString();

  console.log("Booking source captured on appointment page:", src);

  // 5️⃣ Append source to internal links
  document.addEventListener("DOMContentLoaded", function () {
    document.querySelectorAll('a[href*="/pages/"]').forEach(function (link) {
      var href = link.getAttribute('href') || '';
      if (!href || href.indexOf('source=') !== -1) return;

      link.href =
        href +
        (href.indexOf('?') === -1
          ? '?source=' + encodeURIComponent(src)
          : '&source=' + encodeURIComponent(src));
    });
    console.log("Boutique links updated with source:", src);
  });

} catch (err) {
  console.error("capture-source error:", err);
}
</script>
