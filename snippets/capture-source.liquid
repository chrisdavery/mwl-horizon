<script>
try {
  var urlParams = new URLSearchParams(window.location.search);
  var src = urlParams.get('source');

  if (!src) {
    var m = document.cookie.match(/(?:^|; )booking_source=([^;]+)/);
    src = m ? decodeURIComponent(m[1]) : "direct";
  } else {
    var d = new Date();
    d.setTime(d.getTime() + 24*60*60*1000);
    document.cookie = "booking_source=" + encodeURIComponent(src) + "; path=/; expires=" + d.toUTCString();
  }

  //console.log("Booking source captured on appointment page:", src);

  document.addEventListener("DOMContentLoaded", function() {
    document.querySelectorAll('a[href*="/pages/"]').forEach(function(link) {
      var href = link.getAttribute('href') || '';
      if (!href || href.indexOf('source=') !== -1) return;

      link.href = href + (href.indexOf('?') === -1 ? '?source=' + encodeURIComponent(src) : '&source=' + encodeURIComponent(src));
    });
    //console.log("Boutique links updated with source:", src);
  });

} catch(err) {
  //console.error("capture-source error:", err);
}
</script>