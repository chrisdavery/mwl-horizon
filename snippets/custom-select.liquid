{%- doc -%}
  Renders block content for all blocks that extend the group block.
  @param {boolean} [required] - required
  @param {boolean} [default_empty] - required
  @param {string} [class] - Custom classes for the group block.
  @param {object} [product_option] - The object of product_option
  @param {boolean} use_product - boolean
  @param {string} label - label
  @param {string} id - id
  @param {object} options - The object of options

  @example
  {% render 'custom-select', children: children, settings: block.settings, shopify_attributes: block.shopify_attributes %}
{%- enddoc -%}

<custom-input class="custom-dropdown--field">
    <div class="custom-select-wrapper hidden">
        <custom-select>
            <select
                {% if use_product %}
                    name="options[{{ product_option.name | escape }}]"
                {% else %}
                    name="properties[{{ label | escape }}]"
                {% endif %}
                id="{{ id }}"
                class="{{ class }} custom-form__dropdown hidden"
                {% if required == true %}required{% endif %}
            >
                {% if default_empty == true %}
                    <option selected disabled></option>
                {% endif %}
                {%- for option in options -%}
                    <option
                        value="{{ option | escape }}"
                        {% if use_product %}
                            data-input-id="{{ product_option.position }}-{{ forloop.index0 }}"
                            data-option-value-id="{{ option.id }}"
                            data-variant-id="{{ option.variant.id }}"
                            data-connected-product-url="{{ option.product_url }}"
                            {% if option.selected %}
                                selected="selected"
                            {% endif %}
                        {% else %}
                            data-input-id="drop-{{ option | handleize }}-{{ forloop.index0 }}"
                        {% endif %}
                    >
                        {% if use_product %}
                            {% if option.available == false %}
                                {{ option | escape }} - {{ 'content.unavailable' | t }}
                            {% else %}
                                {{ option | escape }}
                            {% endif %}
                        {% else %}
                            {{ option | escape }}
                        {% endif %}
                    </option>
                {%- endfor -%}
            </select>
        </custom-select>
        <label for="{{ id }}">
            {{ label | escape }}{% if required %}<span aria-hidden="true">*</span>{% endif %}
        </label>
        {% if required == true %}
            <div class="error-message hidden">
                {{'accessibility.is_required' | t: value: label }}
            </div>
        {% endif %}

        <svg
            aria-hidden="true"
            focusable="false"
            class="icon icon-caret"
            viewBox="0 0 10 6"
        >
            {%- render 'icon', icon: 'caret' -%}
        </svg>
    </div>
</custom-input>

{% stylesheet %}
    .custom-select-wrapper {
        position: relative;
    }

    .error-message {
        margin-top: var(--margin-2xs);
        line-height: 1em;
    }

    .custom-select-wrapper label {
        position: absolute;
        top: 1rem;
        left: var(--margin-xl);
        pointer-events: none;
        transition: all var(--hover-transition-duration) cubic-bezier(.4,0,.2,1);
        width: calc(100% - var(--margin-xl));
        line-height: 1em;
        z-index: 1;
    }
    .custom-select-wrapper .icon {
        position: absolute;
        right: var(--padding-md);
        top: 50%;
        transform: translateY(-50%);
        width: var(--icon-size-2xs);
        height: var(--icon-size-2xs);
        pointer-events: none;
    }
    /* When no real selection is made (placeholder is selected) */
    custom-select.has-value + label {
        font-size: var(--font-size--xs);
        letter-spacing: .2px;
        top: 6px;
    }

    .custom-select-wrapper .error-message {
        margin-top: var(--margin-2xs);
        line-height: 1em;
    }

    .has-error .error-message {
        display: block !important;
        color: var(--color-primary-hover);
    }

    .custom-dropdown--field.has-error label {
        color: var(--color-primary-hover);
    }

    .custom-dropdown--field.has-error {
        --color-input-border: var(--color-primary-hover);
    }
    
    .custom-select {
        position: relative;
        width: 100%;
        border: .1rem solid var(--color-border);
        padding: var(--padding-lg) var(--padding-xl) var(--padding-2xs);
        background-color: var(--color-background);
        box-sizing: border-box;
    }
    
    .custom-select-wrapper label [aria-hidden="true"] {
        margin-left: .2rem;
        line-height: 1em;
        position: relative;
        bottom: -.1rem;
    }

    .cs-display {
        cursor: pointer;
        font: inherit;
        min-height: var(--font-size--2xl);
        line-height: 1em;
        display: flex;
        align-items: center;
        -webkit-tap-highlight-color: transparent;
    }

    .cs-menu {
        position: absolute;
        left: 0;
        right: 0;
        border: .1rem solid var(--color-border);
        background-color: var(--color-background);
        display: none;
        max-height: 300px;
        overflow-y: auto;
        z-index: 1000;
        top: 100%;
    }

    .cs-option {
        padding: var(--padding-sm) var(--padding-lg);
        cursor: pointer;
    }

    .cs-option.selected {
        background: rgb(248 246 239 / 1.0);
    }
    .cs-option:hover {
        background: rgb(248 246 239 / 0.5);
    }

    .cs-menu.open {
        display: block;
    }
{% endstylesheet %}